<UserControl x:Class="CRM.Modular.Views.FbmPurchaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CRM.Modular.Views"
             xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:t="clr-namespace:Aipark.Wpf.Controls;assembly=Aipark.Wpf.Controls"
             xmlns:cm="http://caliburnmicro.com"
             mc:Ignorable="d"
             Language="zh-CN"
             d:DesignHeight="1080" d:DesignWidth="1920">
    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="Height" Value="50"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style x:Key="ReadOnlyCell" TargetType="{x:Type TextBox}" BasedOn="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}">
                <Setter Property="IsReadOnly" Value="True"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="开始日期："/>
            <DatePicker Width="140" SelectedDateFormat="Long"
                        SelectedDate="{Binding SelectedStartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="结束日期：" Margin="12,0,0,0"/>
            <DatePicker Width="140" Margin="10,0,0,0" SelectedDateFormat="Long"
                        SelectedDate="{Binding SelectedEndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="采购账号：" Margin="12,0,0,0"/>
            <ComboBox Width="160" Margin="10,0,0,0"
                      ItemsSource="{Binding AccountFilterList}"
                      SelectedItem="{Binding SelectedFilterAccount, Mode=TwoWay}"/>
            <TextBlock Text="业务员：" Margin="12,0,0,0"/>
            <ComboBox Width="140" Margin="10,0,0,0"
                      ItemsSource="{Binding RoleSource}"
                      DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectRole, Mode=TwoWay}"/>
            <TextBox x:Name="OrderIdSearch" wpf:HintAssist.Hint="订单号" MinWidth="160" Margin="12,0,0,0"/>
            <Button x:Name="Query" Width="80" Height="35" Content="查询" Margin="12,0,0,0"/>
            <Button x:Name="Add" Width="80" Height="35" Content="新增" Margin="10,0,0,0"/>
        </StackPanel>

        <DataGrid x:Name="RecordLst"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  LoadingRow="Lst_LoadingRow"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectedItem="{Binding SelectItem}"
                  VerticalAlignment="Stretch"
                  cm:Message.Attach="[Event MouseDoubleClick] = [Action Record_MouseDoubleClick($source,$eventArgs)]">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="序号" Width="56" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Header}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="采购时间" Width="120"
                                    Binding="{Binding PurchaseDate, StringFormat='{}{0:yyyy-MM-dd}'}"
                                    ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="订单号" Width="160" Binding="{Binding OrderId}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="采购金额" Width="120"
                                    Binding="{Binding Expense, StringFormat={}{0:F2}}"
                                    ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="业务员" Width="100" Binding="{Binding BuyerName}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="采购账号" Width="180" Binding="{Binding AccountName}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="支付方式" Width="100" Binding="{Binding PaymentDisplay}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="备注" Width="*" Binding="{Binding Remark}" ElementStyle="{x:Null}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Center">
            <t:Pagination x:Name="Pagination" Height="40"
                          PageNumber="{Binding PageInfo.PageNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ItemsCount="{Binding PageInfo.Total}"
                          PageSize="{Binding PageInfo.PageSize}"
                          PagesCount="{Binding PageInfo.PagesCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          PageSizeOptionsEnable="False"
                          cm:Message.Attach="[Event PageNumberChanged]= [Action Pagination_OnPageNumberChanged($source,$eventArgs)]"/>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="4">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="True">
                            <Setter Property="Background" Value="#55eaeaea"/>
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <t:ProgressRing HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsIndeterminate="{Binding IsProgressIndeterminate}"/>
        </Grid>
    </Grid>
</UserControl>
