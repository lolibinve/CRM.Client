<Window x:Class="CRM.Modular.Views.AddExchangeRateView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRM.Modular.Views"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="510" Width="350" WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow">

    <Window.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="Height" Value="50"></Setter>
                <Setter Property="Margin" Value="10,0,0,0"></Setter>
                <Setter Property="Padding" Value="0,0,0,3"></Setter>
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
                <Setter Property="VerticalContentAlignment" Value="Center"></Setter>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
                <Setter Property="HorizontalAlignment" Value="Right"></Setter>
                <Setter Property="Foreground" Value="#A7A7A7"></Setter>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>


    <Grid Margin="0,30,0,0">
        <Grid.ColumnDefinitions >
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="20"/>
            <ColumnDefinition />
            <ColumnDefinition  Width="80"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions >
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
            <RowDefinition Height="45"/>
        </Grid.RowDefinitions>

        <TextBlock Text="货币代码:" Grid.Column="0" Grid.Row="0" />
        <TextBox Grid.Column="2" Grid.Row="0" Text="{Binding exchange.Country}" Style="{StaticResource MaterialDesignTextBox}" VerticalAlignment="Center"/>
        
        <TextBlock Text="外汇汇率:" Grid.Column="0"  Grid.Row="1"/>
        <TextBox Grid.Column="2" Grid.Row="1" IsEnabled="False" Text="{Binding exchange.Ratio}" Style="{StaticResource MaterialDesignTextBox}" VerticalAlignment="Center"/>

        <TextBlock Text="回款汇率:" Grid.Column="0"  Grid.Row="2"   />
        <TextBox Grid.Column="2" Grid.Row="2" IsEnabled="False" Text="{Binding exchange.BackRatio}" Style="{StaticResource MaterialDesignTextBox}" VerticalAlignment="Center"/>

        
        
        <TextBlock Text="中转货币:" Grid.Column="0"  Grid.Row="3"   />
        <TextBox Grid.Column="2" Grid.Row="3"  Text="{Binding exchange.MidCurrency}" Style="{StaticResource MaterialDesignTextBox}" VerticalAlignment="Center"/>

        <TextBlock Text="原外汇汇率:" Grid.Column="0"  Grid.Row="4"   />
        <TextBox Grid.Column="2" Grid.Row="4"  Text="{Binding exchange.InitRatio}" Style="{StaticResource MaterialDesignTextBox}" VerticalAlignment="Center"/>

        <TextBlock Text="原回款汇率:" Grid.Column="0"  Grid.Row="5"   />
        <TextBox Grid.Column="2" Grid.Row="5" Text="{Binding exchange.InitBackRatio}" Style="{StaticResource MaterialDesignTextBox}" VerticalAlignment="Center"/>

        <TextBlock Text="汇损:" Grid.Column="0"  Grid.Row="6"   />
        <TextBox Grid.Column="2" Grid.Row="6"  Text="{Binding exchange.Dv}" Style="{StaticResource MaterialDesignTextBox}" VerticalAlignment="Center"/>

        
        <TextBlock Text="是否按百分比汇损:" Grid.Column="0"  Grid.Row="7"   />
        <CheckBox Grid.Column="2" Grid.Row="7" IsChecked="{Binding exchange.IsDvPercent}"></CheckBox>


        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="8" Grid.ColumnSpan="4" Grid.Column="0" >
            <Button Name="CloseForm" Content="取消" Height="30" Width="70" />
            <Button Name="Sure" Content="确认" Height="30" Width="70" Margin="50,0,0,0"/>
        </StackPanel>

    </Grid>
</Window>
