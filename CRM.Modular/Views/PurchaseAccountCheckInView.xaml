<Window x:Class="CRM.Modular.Views.PurchaseAccountCheckInView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Language="zh-CN"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="400" Width="480" WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow">
    <Window.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="Height" Value="45"/>
                <Setter Property="Margin" Value="10,0,0,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Foreground" Value="#A7A7A7"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20,22,20,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="55"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="55"/>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="转入资金:"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 Text="{Binding AmountInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="资金类型:"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
            <RadioButton Width="100" Height="35"
                         Content="现金"
                         GroupName="CheckInFundType"
                         IsChecked="{Binding IsCashType, Mode=TwoWay}"
                         Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"/>
            <RadioButton Width="140" Height="35" Margin="16,0,0,0"
                         Content="到期诚意赊"
                         GroupName="CheckInFundType"
                         IsChecked="{Binding IsCreditType, Mode=TwoWay}"
                         Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="备注:"/>
        <TextBox Grid.Row="2" Grid.Column="1" Grid.RowSpan="2"
                 Text="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="8"
                 Style="{StaticResource MaterialDesignFilledTextBox}" Margin="10,6,0,0"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button Name="CloseForm" Content="取消" Height="32" Width="90"/>
            <Button Name="Sure" Content="确认入账" Height="32" Width="100" Margin="40,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
