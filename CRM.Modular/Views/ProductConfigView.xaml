<UserControl x:Class="CRM.Modular.Views.ProductConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CRM.Modular.Views"
             xmlns:cm="http://caliburnmicro.com"
             xmlns:t="clr-namespace:Aipark.Wpf.Controls;assembly=Aipark.Wpf.Controls"
             xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             Language="zh-CN"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" >
                <Setter Property="VerticalContentAlignment" Value="Center"></Setter>
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
                <Setter Property="Width" Value="100" ></Setter>
                <Setter Property="Height" Value="30" ></Setter>
            </Style>
            <Style TargetType="TextBlock" >
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition />
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBlock Text="开始日期：" />
            <DatePicker SelectedDate="{Binding SelectedStartDate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="120" SelectedDateFormat="Long"/>
            <TextBlock Text="结束日期：" Margin="20,0,0,0"/>
            <DatePicker SelectedDate="{Binding SelectedEndDate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="10,0,0,0" SelectedDateFormat="Long"/>
            <TextBlock Text="SKU：" Margin="20,0,0,0"/>
            <TextBox  x:Name="Sku" Width="100" />

            <TextBlock Text="业务员：" Margin="20,0,0,0" Visibility="{Binding IsAdmin,Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <ComboBox x:Name="SaleMan" ItemsSource="{Binding RoleSource}" Width="120" SelectedItem="{Binding SelectRole}"
                      Visibility="{Binding IsAdmin,Converter={StaticResource BooleanToVisibilityConverter}}"
                      Margin="10,0,0,0" DisplayMemberPath="Name" SelectedValuePath="Name"/>

            <Button x:Name="Query" Margin="20,0,0,0" Width="80" Content="查询" />
            <Button x:Name="Delete" Margin="10,0,0,0" Width="80" Content="删除"/>
            <Button x:Name="Add" Margin="10,0,0,0" Width="80" Content="新增"/>
        </StackPanel>

        <DataGrid x:Name="ProductLst" Grid.Row="1" AutoGenerateColumns="False"
                  LoadingRow="Lst_LoadingRow"
                  CanUserAddRows="False"
                  SelectedItem="{Binding SelectData}" IsReadOnly="True"
                  cm:Message.Attach="[Event MouseDoubleClick] = [Action ProductLst_MouseDoubleClick($source,$eventArgs)]"
                  VerticalAlignment="Top" >

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="选中" IsReadOnly="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox  Style="{StaticResource MaterialDesignAccentCheckBox}" 
                                       IsThreeState="False" 
                                       cm:Message.Attach="[Event Click] = [Action OrderItem_CheckedClick($source,$eventArgs)]"
                                       IsChecked="{Binding IsCheck,UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="序号" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}" HorizontalAlignment="Left" VerticalAlignment="Center" ></TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="SKU" Width="200" Binding="{Binding Sku,UpdateSourceTrigger=PropertyChanged}"  ElementStyle="{x:Null}"/>
                <DataGridTemplateColumn Header="图片" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate >
                            <!--<Image Width="50" Height="50" Source="{Binding ImageBase64Str,UpdateSourceTrigger=PropertyChanged,Converter={StaticResource Base64ImageConverter}}">
                                <Image.ToolTip>
                                    <Image Width="120" Height="120" Source="{Binding ImageBase64Str,UpdateSourceTrigger=PropertyChanged,Converter={StaticResource Base64ImageConverter}}"/>
                                </Image.ToolTip>
                            </Image>-->

                            <Image Width="50" Height="50">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsImageUrl}" Value="1">
                                                <Setter Property="Source" Value="{Binding ImageUrl}"></Setter>
                                                <Setter Property="ToolTip">
                                                    <Setter.Value>
                                                        <Image Width="120" Height="120" Source="{Binding ImageUrl}"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsImageUrl}" Value="0">
                                                <Setter Property="Source" Value="{Binding ImageBase64Str,UpdateSourceTrigger=PropertyChanged,Converter={StaticResource Base64ImageConverter}}"></Setter>
                                                <Setter Property="ToolTip" >
                                                    <Setter.Value>
                                                        <Image Width="120" Height="120" Source="{Binding ImageBase64Str,UpdateSourceTrigger=PropertyChanged,Converter={StaticResource Base64ImageConverter}}"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!--<DataGridTemplateColumn Header="操作" Width="200">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button  cm:Message.Attach="[Event Click] = [Action AddPic($source)]">上传图片</Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->
                <DataGridTextColumn Header="添加人"  Binding="{Binding Operator,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="添加日期" Width="150"  Binding="{Binding Date,StringFormat='{}{0:yyyy-MM-dd}',UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="备注" Width="200" Binding="{Binding Remark,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
            </DataGrid.Columns>
        </DataGrid>

        
        <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Grid.Row="2">
            <t:Pagination 
                x:Name="Pagination" Height="40" 
                PageNumber="{Binding PageInfo.PageNum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                ItemsCount="{Binding PageInfo.Total}" 
                PageSize="{Binding PageInfo.PageSize}" 
                PagesCount ="{Binding PageInfo.PagesCount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                PageSizeOptionsEnable="False"
                cm:Message.Attach="[Event PageNumberChanged]= [Action Pagination_OnPageNumberChanged($source,$eventArgs)]"
                ></t:Pagination>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="3">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="True">
                            <Setter Property="Background" Value="#55eaeaea"/>
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <t:ProgressRing Grid.Row="0" Grid.RowSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center" IsIndeterminate="{Binding IsProgressIndeterminate}"/>
        </Grid>

    </Grid>
</UserControl>
