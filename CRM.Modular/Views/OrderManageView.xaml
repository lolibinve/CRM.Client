<UserControl x:Class="CRM.Modular.Views.OrderManageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:CRM.Modular.Views"
             xmlns:t="clr-namespace:Aipark.Wpf.Controls;assembly=Aipark.Wpf.Controls"
             xmlns:cm="http://caliburnmicro.com"
             mc:Ignorable="d" 
             Language="zh-CN"
             d:DesignHeight="1080" d:DesignWidth="1920">
    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="Height" Value="50"></Setter>
            </Style>
            <Style TargetType="TextBlock" >
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
            </Style>
            <Style x:Key="EditingStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}">
                <Setter Property="IsReadOnly" Value="True"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>


    <Grid >

        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" >

            <TextBlock Text="开始日期：" Margin="0,0,0,0"/>
            <DatePicker SelectedDate="{Binding SelectedStartDate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="120" SelectedDateFormat="Long"/>
            <TextBlock Text="结束日期：" Margin="10,0,0,0"/>
            <DatePicker SelectedDate="{Binding SelectedEndDate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="10,0,0,0" SelectedDateFormat="Long"/>
            <TextBlock Text="业务员：" Margin="10,0,0,0" Visibility="{Binding IsAdmin,Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <ComboBox x:Name="SaleMan" ItemsSource="{Binding RoleSource}" Width="120" SelectedItem="{Binding SelectRole}"
                      Visibility="{Binding IsAdmin,Converter={StaticResource BooleanToVisibilityConverter}}"
                      DisplayMemberPath="Name" SelectedValuePath="Name"/>

            <TextBlock Text="国家：" Margin="10,0,0,0" />
            <ComboBox ItemsSource="{Binding Countries}"
                      Width="120" SelectedValue="{Binding SelectCountry}" SelectedValuePath="Code" DisplayMemberPath="Country_Code"></ComboBox>
            
            <TextBox x:Name="SKUStr" wpf:HintAssist.Hint="SKU"  Margin="10,0,0,0" MinWidth="120" />
            <TextBox x:Name="OrderNumber" wpf:HintAssist.Hint="订单号"  Margin="10,0,0,0" MinWidth="120" />
            <!--<TextBox x:Name="Country" wpf:HintAssist.Hint="国家"  Margin="10,0,0,0" MinWidth="100"/>-->
            <TextBox x:Name="Store" wpf:HintAssist.Hint="店铺"  Margin="10,0,0,0" MinWidth="100"/>
            <Button x:Name="Query" Width="80" Height="35" Content="查询" Margin="10,0,0,0" />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,20">
            <Button
                x:Name="Import" Height="35"
                Style="{StaticResource MaterialDesignFlatLightBgButton}"
                materialDesign:ButtonProgressAssist.Value="-1"
                materialDesign:ButtonProgressAssist.IsIndicatorVisible="True"
                materialDesign:ButtonProgressAssist.IsIndeterminate="{Binding ImportAnimation}"
                ToolTip="需要添加 settle-amount  shop"
                Content="导入" Width="80" Margin="0,0,0,0"/>

            <Button
                x:Name="Export" Height="35"
                Style="{StaticResource MaterialDesignFlatLightBgButton}"
                materialDesign:ButtonProgressAssist.Value="-1"
                materialDesign:ButtonProgressAssist.IsIndicatorVisible="True"
                materialDesign:ButtonProgressAssist.IsIndeterminate="{Binding ExportAnimation}"
                Content="导出" Width="80" Margin="10,0,10,0"/>

            <Button x:Name="Complete" Width="80" Height="35" Content="妥投" Margin="10,0,0,0"/>
            <Button x:Name="Send" Width="80" Height="35" Content="发货" Margin="10,0,0,0"  />
            <Button x:Name="Modify" Width="80" Height="35" Content="修改" Margin="10,0,0,0" />
            <Button x:Name="Delete" Width="80" Height="35" Content="删除" Margin="10,0,0,0" Visibility="{Binding IsAdmin,Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <!--<Button x:Name="CopyAdd" Width="130" Height="35" Content="新增补发订单" Margin="10,0,0,0" />-->

        </StackPanel>


        <Grid Grid.Row="2" Background="Transparent"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Bottom">

            <materialDesign:Badged Badge="{Binding Badged0}" >
                <RadioButton Width="80" Height="35" IsChecked="{Binding statusNew}"
                        cm:Message.Attach="[Event Click]= [Action StateQuery(0)]"
                        Content="新单" Margin="0,0,0,0" GroupName="group" Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"></RadioButton>
            </materialDesign:Badged>
            <materialDesign:Badged Badge="{Binding Badged1}">
                <RadioButton Width="80" Height="35"  IsChecked="{Binding statusPrepare}"
                        cm:Message.Attach="[Event Click]= [Action StateQuery(1)]"
                        Content="备货" Margin="10,0,0,0" GroupName="group" Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"></RadioButton>
            </materialDesign:Badged>
            <materialDesign:Badged Badge="{Binding Badged2}">
                <RadioButton Width="80" Height="35"  IsChecked="{Binding statusSend}"
                        cm:Message.Attach="[Event Click]= [Action StateQuery(2)]"
                        Content="发货" Margin="10,0,0,0" GroupName="group" Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"></RadioButton>
            </materialDesign:Badged>
            <materialDesign:Badged Badge="{Binding Badged3}">
                <RadioButton Width="80" Height="35" IsChecked="{Binding statusWrong}"
                        cm:Message.Attach="[Event Click]= [Action StateQuery(4)]"
                        Content="退款" Margin="10,0,0,0" GroupName="group" Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"></RadioButton>
            </materialDesign:Badged>
            <materialDesign:Badged Badge="{Binding Badged4}">
                <RadioButton Width="80" Height="35" IsChecked="{Binding statusDone}"
                        cm:Message.Attach="[Event Click]= [Action StateQuery(3)]"
                        Content="妥投" Margin="10,0,0,0" GroupName="group" Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"></RadioButton>
            </materialDesign:Badged>
            <materialDesign:Badged Badge="{Binding Badged}">
                <RadioButton Width="80" Height="35"  IsChecked="{Binding statusAll}"
                        cm:Message.Attach="[Event Click]= [Action StateQuery(-1)]"
                        Content="全部" Margin="10,0,0,0" GroupName="group" Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"></RadioButton>
            </materialDesign:Badged>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" >
            <TextBlock Text="销售利润率:"/>
            <TextBlock x:Name="ProfitRatio" Margin="10,0,0,0" Width="80" />
            <TextBlock Text="销售额:"/>
            <TextBlock x:Name="TotalSales" Margin="10,0,0,0" Width="80"/>
            <TextBlock Text="成本:"/>
            <TextBlock x:Name="TotalCost" Margin="10,0,0,0" Width="80"/>
            <TextBlock Text="运费:"/>
            <TextBlock x:Name="TotalTrans" Margin="10,0,0,0" Width="80"/>
            <TextBlock Text="利润:"/>
            <TextBlock x:Name="TotalProfit" Margin="10,0,0,0" Width="80"/>
        </StackPanel>


        <DataGrid x:Name="OrderLst" Grid.Row="4" AutoGenerateColumns="False"
                  LoadingRow="Lst_LoadingRow" CanUserAddRows="False" VerticalAlignment="Top"
                  SelectedItem="{Binding SelectOrder}"  SelectionMode="Single"
                  cm:Message.Attach="
                  [Event MouseDoubleClick] = [Action OrderLst_MouseDoubleClick($source,$eventArgs)]"
                  >
            <DataGrid.Columns>

                <DataGridTemplateColumn Header="选中" IsReadOnly="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox  Style="{StaticResource MaterialDesignAccentCheckBox}" 
                                       IsThreeState="False" 
                                       cm:Message.Attach="[Event Click] = [Action OrderItem_CheckedClick($source,$eventArgs)]"
                                       IsChecked="{Binding IsCheck,UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!--<DataGridTemplateColumn Header="序号" Width="60" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}"  HorizontalAlignment="Stretch" VerticalAlignment="Center" ></TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->
                <DataGridTextColumn Header="订单号"  Binding="{Binding OrderNumber}" EditingElementStyle="{StaticResource EditingStyle}" ElementStyle="{x:Null}"></DataGridTextColumn>
                <DataGridTextColumn Header="SKU"  Binding="{Binding SKU}"  EditingElementStyle="{StaticResource EditingStyle}"  ElementStyle="{x:Null}"></DataGridTextColumn>
                <DataGridTemplateColumn Header="图片" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate >
                            <Image Width="50" Height="50">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsImageUrl}" Value="1">
                                                <Setter Property="Source" Value="{Binding ImageBase64Str}"></Setter>
                                                <Setter Property="ToolTip">
                                                    <Setter.Value>
                                                        <Image Width="120" Height="120" Source="{Binding ImageBase64Str}"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsImageUrl}" Value="0">
                                                <Setter Property="Source" Value="{Binding ImageBase64Str,UpdateSourceTrigger=PropertyChanged,Converter={StaticResource Base64ImageConverter}}"></Setter>
                                                <Setter Property="ToolTip" >
                                                    <Setter.Value>
                                                        <Image Width="120" Height="120" Source="{Binding ImageBase64Str,UpdateSourceTrigger=PropertyChanged,Converter={StaticResource Base64ImageConverter}}"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
               
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="业务员"  Binding="{Binding Account}" IsReadOnly="True" ElementStyle="{x:Null}"></DataGridTextColumn>
                <DataGridTextColumn Header="国家"  Binding="{Binding Country}" IsReadOnly="True" ElementStyle="{x:Null}"></DataGridTextColumn>
                <!--<DataGridTextColumn Header="货币"  Binding="{Binding MoneyType}" IsReadOnly="True"  ElementStyle="{x:Null}"></DataGridTextColumn>
                <DataGridTextColumn Header="购买数"  Binding="{Binding QuantityPurchased,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}" IsReadOnly="True"/>
                <DataGridTextColumn Header="结算金额"  Binding="{Binding SettleAmount,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" ElementStyle="{x:Null}"/>-->
                <!--<DataGridTextColumn Header="外汇汇率"  Binding="{Binding ExchangeRafe,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                <DataGridTextColumn Header="外汇金额"  Binding="{Binding ExchangeAmount,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                <DataGridTextColumn Header="回款汇率"  Binding="{Binding BackExchange,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>-->
                <DataGridTextColumn Header="销售额（¥）"  Binding="{Binding SalesVolume,StringFormat={}{0:F2},UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" ElementStyle="{x:Null}"/>

                <DataGridTextColumn Header="成本（¥）"  Binding="{Binding Cost,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="运费（¥）"  Binding="{Binding TransExpense,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="退款（¥）"  Binding="{Binding BackAmount,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" ElementStyle="{x:Null}"/>

                <DataGridTextColumn Header="利润（¥）"  Binding="{Binding Profit,StringFormat={}{0:F2},UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="利润率"  Binding="{Binding ProfitRate,UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="状态"  Binding="{Binding State,UpdateSourceTrigger=PropertyChanged,Converter={StaticResource EnumStrConverter}}" IsReadOnly="True" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="店铺"  Binding="{Binding Store}" ElementStyle="{x:Null}" IsReadOnly="True"></DataGridTextColumn>
                <DataGridTextColumn Header="日期"  Binding="{Binding SaleDate,StringFormat='{}{0:yyyy-MM-dd}'}" ElementStyle="{x:Null}" IsReadOnly="True"></DataGridTextColumn>
                <DataGridTextColumn Header="备注"  Binding="{Binding Remark,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}" IsReadOnly="True"/>

            </DataGrid.Columns>
        </DataGrid>


        <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Grid.Row="5">
            <t:Pagination 
                x:Name="Pagination" Height="40" 
                PageNumber="{Binding PageInfo.PageNum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                ItemsCount="{Binding PageInfo.Total}" 
                PageSize="{Binding PageInfo.PageSize}" 
                PagesCount ="{Binding PageInfo.PagesCount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                PageSizeOptionsEnable="False"
                cm:Message.Attach="[Event PageNumberChanged]= [Action Pagination_OnPageNumberChanged($source,$eventArgs)]"
                ></t:Pagination>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="6">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="True">
                            <Setter Property="Background" Value="#55eaeaea"/>
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <t:ProgressRing Grid.Row="0" Grid.RowSpan="4" HorizontalAlignment="Center" VerticalAlignment="Center" IsIndeterminate="{Binding IsProgressIndeterminate}"/>
        </Grid>
    </Grid>
</UserControl>
