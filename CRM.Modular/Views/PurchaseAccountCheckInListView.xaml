<Window x:Class="CRM.Modular.Views.PurchaseAccountCheckInListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:t="clr-namespace:Aipark.Wpf.Controls;assembly=Aipark.Wpf.Controls"
        xmlns:cm="http://caliburnmicro.com"
        mc:Ignorable="d"
        Language="zh-CN"
        Title="{Binding WindowTitle}"
        Height="620" Width="1020"
        MinHeight="480" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">
    <Window.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="账户名称：" Foreground="#888"/>
            <TextBlock Text="{Binding AccountName}" FontWeight="SemiBold" Margin="4,0,20,0"/>
            <TextBlock Text="开始日期：" Margin="0,0,4,0"/>
            <DatePicker Width="128" Margin="0,0,16,0" VerticalAlignment="Center"
                        SelectedDate="{Binding FilterStartDate, Mode=TwoWay}"/>
            <TextBlock Text="结束日期：" Margin="0,0,4,0"/>
            <DatePicker Width="128" Margin="0,0,16,0" VerticalAlignment="Center"
                        SelectedDate="{Binding FilterEndDate, Mode=TwoWay}"/>
            <TextBlock Text="资金类型：" Margin="0,0,4,0"/>
            <ComboBox Width="132" Margin="0,0,12,0" VerticalAlignment="Center"
                      ItemsSource="{Binding FundTypeFilters}"
                      DisplayMemberPath="Label"
                      SelectedItem="{Binding SelectedFundType, Mode=TwoWay}"/>
            <Button x:Name="Query" Content="查询" Width="80" Height="32" VerticalAlignment="Center"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
            <Button x:Name="CloseWindow" Content="关闭" Width="72" Height="32" VerticalAlignment="Center" Margin="12,0,0,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
        </StackPanel>

        <Border Grid.Row="1" Padding="12,10" Margin="0,0,0,10" Background="#F5F5F5" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="现金存入合计：" Foreground="#666"/>
                <TextBlock Text="{Binding SumCheckInCash, StringFormat='{}{0:N2}'}" FontWeight="SemiBold" Margin="4,0,32,0"/>
                <TextBlock Text="账期/诚意赊存入合计：" Foreground="#666"/>
                <TextBlock Text="{Binding SumCheckInDebt, StringFormat='{}{0:N2}'}" FontWeight="SemiBold" Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="RecordLst"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  LoadingRow="Lst_LoadingRow"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  VerticalAlignment="Stretch">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="序号" Width="56" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Header}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="账户名称" Width="160" Binding="{Binding AccountName}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="存入金额" Width="120" Binding="{Binding Amount}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="资金类型" Width="120" Binding="{Binding TypeDisplay}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="存入时间" Width="170" Binding="{Binding AddTimeDisplay}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="备注" Width="*" Binding="{Binding Remark}" ElementStyle="{x:Null}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" HorizontalAlignment="Right" VerticalAlignment="Center">
            <t:Pagination x:Name="Pagination" Height="40"
                          PageNumber="{Binding PageInfo.PageNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ItemsCount="{Binding PageInfo.Total}"
                          PageSize="{Binding PageInfo.PageSize}"
                          PagesCount="{Binding PageInfo.PagesCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          PageSizeOptionsEnable="True"
                          cm:Message.Attach="[Event PageNumberChanged]= [Action Pagination_OnPageNumberChanged($source,$eventArgs)]"/>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="4" Panel.ZIndex="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="True">
                            <Setter Property="Background" Value="#55eaeaea"/>
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <t:ProgressRing HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsIndeterminate="{Binding IsProgressIndeterminate}"/>
        </Grid>
    </Grid>
</Window>
