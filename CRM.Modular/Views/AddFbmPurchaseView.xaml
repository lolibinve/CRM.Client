<Window x:Class="CRM.Modular.Views.AddFbmPurchaseView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRM.Modular.Views"
        Language="zh-CN"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="480" Width="620"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow">
    <Window.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="Height" Value="45"/>
                <Setter Property="Margin" Value="10,0,0,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Foreground" Value="#A7A7A7"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20,22,20,18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="52"/>
            <RowDefinition Height="88"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="订单号:"/>
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4"
                 Text="{Binding Record.OrderId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="采购时间:"/>
        <DatePicker Grid.Row="1" Grid.Column="1" SelectedDateFormat="Long"
                    SelectedDate="{Binding Record.PurchaseDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Grid.Column="3" Text="采购金额:"/>
        <TextBox Grid.Row="1" Grid.Column="4"
                 Text="{Binding Record.Expense, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="业务员:"/>
        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4"
                 Text="{Binding Record.BuyerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="采购账号:"/>
        <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Margin="10,6,0,6"
                  ItemsSource="{Binding AccountOptions}"
                  SelectedItem="{Binding Record.AccountName, Mode=TwoWay}"
                  IsEditable="False"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="支付方式:"/>
        <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Margin="10,6,0,6"
                  ItemsSource="{Binding PaymentItems}"
                  DisplayMemberPath="Display"
                  SelectedItem="{Binding SelectedPayment, Mode=TwoWay}"/>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="备注:" VerticalAlignment="Top" Margin="0,10,0,0"/>
        <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="4"
                 Text="{Binding Record.Remark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="8"
                 Style="{StaticResource MaterialDesignFilledTextBox}" Margin="10,6,0,0"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12,0,0">
            <Button Name="CloseForm" Content="取消" Height="32" Width="90"/>
            <Button Name="Sure" Content="确认" Height="32" Width="90" Margin="40,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
