<Window x:Class="CRM.Client.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:cal="clr-namespace:Caliburn.Micro;assembly=Caliburn.Micro.Platform"
        xmlns:local="clr-namespace:CRM.Client.Views"
        xmlns:help="clr-namespace:CRM.Modular.Help"
        mc:Ignorable="d" AllowsTransparency="True" AllowDrop="True" 
        xmlns:t="clr-namespace:Aipark.Wpf.Controls;assembly=Aipark.Wpf.Controls"
        PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown"
        PreviewMouseMove="Window_PreviewMouseMove"
        PreviewMouseLeftButtonUp="Window_PreviewMouseLeftButtonUp"
        Height="432" Width="700" 
        Background="#00FFFFFF"
        WindowStartupLocation="CenterScreen" WindowState="Normal" WindowStyle="None">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid Background="#FF9933" Grid.Column="0" Opacity="0.8" >
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="auto" />
                <RowDefinition Height="auto" />
                <RowDefinition/>
            </Grid.RowDefinitions>

            <TextBlock HorizontalAlignment="Center" Grid.Row="1" Text="Welcome" FontSize="35" Height="50" Foreground="White"/>
            <TextBlock Grid.Row="2" HorizontalAlignment="Center" Margin="0,20,0,0" Text="订单管理系统" FontSize="38" Height="60" Foreground="White" />
        </Grid>

        <Grid Background="White" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition />
                <RowDefinition Height="0.8*"/>
            </Grid.RowDefinitions>

            <Button x:Name="CloseFrom" Width="28" Grid.Row="0" Grid.Column="2" Height="28" HorizontalAlignment="Right" Padding="0" Margin="10" VerticalAlignment="Top" Content="X" />

            <TextBox x:Name="Uname" Grid.Row="1" Grid.Column="1" Height="50" FontSize="15"
                 wpf:HintAssist.Hint="账号" 
                 wpf:HintAssist.FloatingOffset="0,-20"
                 wpf:HintAssist.IsFloating="True"
                 Style="{StaticResource MaterialDesignFloatingHintTextBox}" />

            <PasswordBox x:Name="Password" Grid.Row="2" Height="50" FontSize="15" Grid.Column="1"
                     wpf:HintAssist.FloatingOffset="0,-20"
                     materialDesign:HintAssist.Hint="密码" 
                     help:PasswordBoxBindingHelper.PasswordContent="{Binding Password,Mode=TwoWay}"
                     cal:Message.Attach="[Event PasswordChanged] = [Action OnPasswordChanged($source)]"
                     Style="{StaticResource MaterialDesignFloatingHintPasswordBox}" />

            <CheckBox Content="记住账号密码" IsChecked="{Binding IsCheck}" Foreground="#6B7A7B" VerticalAlignment="Center" Grid.Row="3" Padding="0,0,0,0"  Grid.Column="1" Margin="0,5,0,0"></CheckBox>

            <Button Grid.Row="4" x:Name="Login" Height="35" Content="登  录"  Grid.Column="1"
                wpf:ButtonAssist.CornerRadius="14"
                IsDefault="True"
                Style="{StaticResource MaterialDesignRaisedButton}"  Cursor="Hand" />

        </Grid>

        <t:ProgressRing Grid.Column="0" Grid.ColumnSpan="2"  HorizontalAlignment="Center" VerticalAlignment="Center" IsIndeterminate="{Binding IsProgressIndeterminate}"/>

    </Grid>
</Window>
