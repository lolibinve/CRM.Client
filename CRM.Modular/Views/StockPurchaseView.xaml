<UserControl x:Class="CRM.Modular.Views.StockPurchaseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CRM.Modular.Views"
             xmlns:t="clr-namespace:Aipark.Wpf.Controls;assembly=Aipark.Wpf.Controls"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cm="http://caliburnmicro.com"
             mc:Ignorable="d"
             Language="zh-CN"
             d:DesignHeight="1080" d:DesignWidth="1920">
    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="库存视图:" Margin="0,0,8,0"
                       ToolTip="模块2 采购运输库存；模块3 到仓库库存；模块4 滞销库存。与 stockList 的 type 一致。"/>
            <materialDesign:Badged Badge="{Binding StockViewBadge0}">
                <RadioButton Width="120" Height="35"
                             IsChecked="{Binding statusTransit}"
                             cm:Message.Attach="[Event Click]= [Action StockTypeQuery(1)]"
                             Content="采购运输库存"
                             Margin="0,0,0,0"
                             GroupName="stockPurchaseType"
                             Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"/>
            </materialDesign:Badged>
            <materialDesign:Badged Badge="{Binding StockViewBadge1}">
                <RadioButton Width="120" Height="35"
                             IsChecked="{Binding statusWarehouse}"
                             cm:Message.Attach="[Event Click]= [Action StockTypeQuery(2)]"
                             Content="到仓库库存"
                             Margin="10,0,0,0"
                             GroupName="stockPurchaseType"
                             Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"/>
            </materialDesign:Badged>
            <materialDesign:Badged Badge="{Binding StockViewBadge2}">
                <RadioButton Width="120" Height="35"
                             IsChecked="{Binding statusDeadstock}"
                             cm:Message.Attach="[Event Click]= [Action StockTypeQuery(3)]"
                             Content="滞销库存"
                             Margin="10,0,0,0"
                             GroupName="stockPurchaseType"
                             Style="{StaticResource MaterialDesignChoiceChipAccentOutlineRadioButton}"/>
            </materialDesign:Badged>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="采购批次:" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBox Width="160" Text="{Binding FilterPurId, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            <TextBlock Text="业务员:" Margin="16,0,8,0" VerticalAlignment="Center"/>
            <TextBox Width="120" Text="{Binding FilterBuyerName, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
            <TextBlock Text="产品编码:" Margin="16,0,8,0" VerticalAlignment="Center"/>
            <TextBox Width="140" Text="{Binding FilterProductCode, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal">
            <Button x:Name="Query" Width="88" Height="35" Content="查询"/>
            <Button x:Name="Add" Width="88" Height="35" Content="新增" Margin="10,0,0,0"/>
        </StackPanel>

        <DataGrid x:Name="RecordLst"
                  Grid.Row="3"
                  AutoGenerateColumns="False"
                  LoadingRow="Lst_LoadingRow"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectedItem="{Binding SelectItem}"
                  VerticalAlignment="Stretch"
                  cm:Message.Attach="[Event MouseDoubleClick] = [Action Record_MouseDoubleClick($source,$eventArgs)]">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="序号" Width="56" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridRow}}, Path=Header}"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="采购批次" Width="130" Binding="{Binding PurId}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="产品编码" Width="120" Binding="{Binding ProductCode}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="产品名称" Width="180" Binding="{Binding ProductName}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="数量" Width="80" Binding="{Binding Quantity}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="采购金额" Width="100" Binding="{Binding Expense}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="单件采购成本" Width="120" Binding="{Binding UnitPurchaseCostDisplay}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="头程运费" Width="100" Binding="{Binding TransFee}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="单件头程" Width="88" Binding="{Binding UnitTransFeeDisplay}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="合计成本(单件)" Width="130" Binding="{Binding TotalUnitCostDisplay}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="支付" Width="72" Binding="{Binding PaymentDisplay}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="业务员" Width="88" Binding="{Binding UserName}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="货件状态" Width="96" Binding="{Binding ShipmentTypeDisplay}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="到仓时间" Width="150"
                                    Binding="{Binding InstockDateTime, StringFormat='{}{0:yyyy-MM-dd}', TargetNullValue=''}"
                                    ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="备注" Width="160" Binding="{Binding Remark}" ElementStyle="{x:Null}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="4" HorizontalAlignment="Right" VerticalAlignment="Center">
            <t:Pagination x:Name="Pagination" Height="40"
                          PageNumber="{Binding PageInfo.PageNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ItemsCount="{Binding PageInfo.Total}"
                          PageSize="{Binding PageInfo.PageSize}"
                          PagesCount="{Binding PageInfo.PagesCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          PageSizeOptionsEnable="False"
                          cm:Message.Attach="[Event PageNumberChanged]= [Action Pagination_OnPageNumberChanged($source,$eventArgs)]"/>
        </Grid>

        <Grid Grid.Row="0" Grid.RowSpan="5">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="True">
                            <Setter Property="Background" Value="#55eaeaea"/>
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsProgressIndeterminate}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <t:ProgressRing HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsIndeterminate="{Binding IsProgressIndeterminate}"/>
        </Grid>
    </Grid>
</UserControl>
