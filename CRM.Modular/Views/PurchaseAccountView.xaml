<UserControl x:Class="CRM.Modular.Views.PurchaseAccountView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CRM.Modular.Views"
             mc:Ignorable="d" 
             xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:t="clr-namespace:Aipark.Wpf.Controls;assembly=Aipark.Wpf.Controls"
             xmlns:cm="http://caliburnmicro.com"
             Language="zh-CN"
             d:DesignHeight="1080" d:DesignWidth="1920">
    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="Height" Value="50"></Setter>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
            </Style>
            <Style x:Key="EditingStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}">
                <Setter Property="IsReadOnly" Value="False"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <TextBlock Text="开始日期："/>
            <DatePicker SelectedDate="{Binding SelectedStartDate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                        Width="140" SelectedDateFormat="Long"/>
            <TextBlock Text="结束日期：" Margin="10,0,0,0"/>
            <DatePicker SelectedDate="{Binding SelectedEndDate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                        Width="140" Margin="10,0,0,0" SelectedDateFormat="Long"/>

            <Button x:Name="Query" Width="80" Height="35" Content="查询" Margin="10,0,0,0"/>
            <Button x:Name="Add" Width="80" Height="35" Content="新增" Margin="10,0,0,0"/>
        </StackPanel>

        <DataGrid x:Name="AccountLst"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  LoadingRow="Lst_LoadingRow"
                  CanUserAddRows="False"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  SelectedItem="{Binding SelectItem}"
                  VerticalAlignment="Top"
                  cm:Message.Attach="[Event MouseDoubleClick] = [Action Account_MouseDoubleClick($source,$eventArgs)]">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="序号" Width="60" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="日期"
                                    Width="160"
                                    Binding="{Binding Date,StringFormat='{}{0:yyyy-MM-dd}',UpdateSourceTrigger=PropertyChanged}"
                                    ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="转入金额"
                                    Width="120"
                                    Binding="{Binding Amount,UpdateSourceTrigger=PropertyChanged}"
                                    EditingElementStyle="{StaticResource EditingStyle}"
                                    ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="采购账号"
                                    Width="200"
                                    Binding="{Binding ProcurementAccount,UpdateSourceTrigger=PropertyChanged}"
                                    EditingElementStyle="{StaticResource EditingStyle}"
                                    ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="资金类型"
                                    Width="160"
                                    Binding="{Binding FundType,UpdateSourceTrigger=PropertyChanged}"
                                    EditingElementStyle="{StaticResource EditingStyle}"
                                    ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="备注"
                                    Width="*"
                                    Binding="{Binding Remark,UpdateSourceTrigger=PropertyChanged}"
                                    EditingElementStyle="{StaticResource EditingStyle}"
                                    ElementStyle="{x:Null}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
