<Window x:Class="CRM.Modular.Views.StandardPriceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRM.Modular.Views"        
        xmlns:cm="http://caliburnmicro.com"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        Title="{Binding Title}" Height="800" Width="800">
    <Window.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="Height" Value="auto"></Setter>
                <Setter Property="VerticalContentAlignment" Value="Center"></Setter>
                <Setter Property="Padding" Value="0"></Setter>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
                <Setter Property="HorizontalAlignment" Value="Right"></Setter>
                <Setter Property="Margin" Value="0,0,10,0"></Setter>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>



    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin=" 10">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="颜色:"  Grid.Row="0"  Grid.Column="0"/>
            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Child.Color}" />

            <TextBlock Text="尺寸:" Grid.Row="1"  Grid.Column="0"  VerticalAlignment="Center"/>
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Child.Size}" />

            <TextBlock Text="主图:" Grid.Row="2"  Grid.Column="0"  VerticalAlignment="Center"/>
            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Child.MainImageUrl}" />

            <TextBlock Text="副图2:" Grid.Row="3"  Grid.Column="0"  VerticalAlignment="Center"/>
            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Child.OtherImageUrl2}" />

            <TextBlock Text="副图4:" Grid.Row="4"  Grid.Column="0"  VerticalAlignment="Center"/>
            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Child.OtherImageUrl4}" />

            <TextBlock Text="库存:"  Grid.Row="0"  Grid.Column="2"/>
            <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Child.Quantity}" />

            <TextBlock Text="零件编号:"  Grid.Row="1"  Grid.Column="2"/>
            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Child.PartNumber}" />

            <TextBlock Text="副图1:"  Grid.Row="2"  Grid.Column="2"/>
            <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding Child.OtherImageUrl1}" />

            <TextBlock Text="副图3:"  Grid.Row="3"  Grid.Column="2"/>
            <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding Child.OtherImageUrl3}" />

            <TextBlock Text="副图5:"  Grid.Row="4"  Grid.Column="2"/>
            <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding Child.OtherImageUrl5}" />

            <TextBlock Text="副图6:" Grid.Row="5"  Grid.Column="0"  VerticalAlignment="Center"/>
            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Child.OtherImageUrl6}" />

            <TextBlock Text="副图7:"  Grid.Row="5"  Grid.Column="2"/>
            <TextBox Grid.Row="5" Grid.Column="3" Text="{Binding Child.OtherImageUrl7}" />

            <TextBlock Text="加价:"  Grid.Row="6"  Grid.Column="2"/>
            <TextBox Grid.Row="6" Grid.Column="3" Text="{Binding Child.PriceDiff}"   cm:Message.Attach="[Event TextChanged] = [Action EditPrice_TextChanged($source,$eventArgs)]"/>

            <TextBlock Text="商品条码:"  Grid.Row="6"  Grid.Column="0"/>
            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Child.ExternalProductId}" />

        </Grid>

        <UniformGrid Grid.Row="1" Height="auto" Columns="8" Margin="0,0,0,5">
            <Grid Grid.Column="0"  Height="auto" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Text="主图" Height="25"></TextBlock>
                <Image Source="{Binding Child.MainImageUrl}"  Grid.Row="1" Height="70"></Image>
            </Grid>
            <Grid Grid.Column="1"  Height="auto" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Text="副图1"></TextBlock>
                <Image Source="{Binding Child.OtherImageUrl1}" Grid.Row="1" Height="70"></Image>
            </Grid>

            <Grid Grid.Column="2"  Height="auto" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Text="副图2"></TextBlock>
                <Image Source="{Binding Child.OtherImageUrl2}" Grid.Row="1" Height="70"></Image>
            </Grid>
            <Grid Grid.Column="3"  Height="auto" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Text="副图3"></TextBlock>
                <Image Source="{Binding Child.OtherImageUrl3}" Grid.Row="1" Height="70"></Image>
            </Grid>
            <Grid Grid.Column="4"  Height="auto" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Text="副图4"></TextBlock>
                <Image Source="{Binding Child.OtherImageUrl4}" Grid.Row="1" Height="70"></Image>
            </Grid>
            <Grid Grid.Column="5"  Height="auto" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Text="副图5"></TextBlock>
                <Image Source="{Binding Child.OtherImageUrl5}" Grid.Row="1" Height="70"></Image>
            </Grid>
            <Grid Grid.Column="6"  Height="auto" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Text="副图6"></TextBlock>
                <Image Source="{Binding Child.OtherImageUrl6}" Grid.Row="1" Height="70"></Image>
            </Grid>
            <Grid Grid.Column="7"  Height="auto" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>
                <TextBlock Text="副图7"></TextBlock>
                <Image Source="{Binding Child.OtherImageUrl7}" Grid.Row="1" Height="70"></Image>
            </Grid>
        </UniformGrid>
        
        
        
        <DataGrid x:Name="PriceLst" Grid.Row="2" AutoGenerateColumns="False" RowHeaderWidth="0" RowHeight="30"
                  SelectedItem="{Binding SelectPrice}" SelectionMode="Single" Margin="30,0,0,0"
                  CanUserAddRows="False" VerticalAlignment="Top" LoadingRow="Lst_LoadingRow">

            <DataGrid.Columns >
                <!--<DataGridTemplateColumn Header="序号" Width="100" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}"  HorizontalAlignment="Stretch" VerticalAlignment="Center" ></TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>-->
                <DataGridTextColumn Header="国家"  Binding="{Binding Country}" Width="100"  ElementStyle="{x:Null}"></DataGridTextColumn>
                <DataGridTextColumn Header="货币"  Binding="{Binding Currency}" Width="100"   ElementStyle="{x:Null}"></DataGridTextColumn>
                <DataGridTextColumn Header="价格"  Binding="{Binding Price}" Width="100"  ElementStyle="{x:Null}"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Center">
            <Button x:Name="CloseForm" Content="取消" Margin="0,0,10,0" Style="{StaticResource MaterialDesignFlatLightBgButton}"></Button>
            <Button x:Name="SavePrices" Content="确定" ></Button>
        </StackPanel>
    </Grid>
</Window>
