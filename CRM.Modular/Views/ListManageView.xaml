<UserControl x:Class="CRM.Modular.Views.ListManageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:cm="http://caliburnmicro.com"
             xmlns:local="clr-namespace:CRM.Modular.Views"            
             xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:t="clr-namespace:Aipark.Wpf.Controls;assembly=Aipark.Wpf.Controls"
             Language="zh-CN"
             mc:Ignorable="d" >
    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
                <Setter Property="Height" Value="50"></Setter>
            </Style>
            <Style TargetType="TextBlock" >
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
            </Style>
            <Style x:Key="EditingStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource MaterialDesignDataGridTextColumnPopupEditingStyle}">
                <Setter Property="IsReadOnly" Value="True"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" >
            <TextBlock Text="开始日期：" Margin="0,0,0,0"/>
            <DatePicker SelectedDate="{Binding SelectedStartDate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="120" SelectedDateFormat="Long"/>
            <TextBlock Text="结束日期：" Margin="10,0,0,0"/>
            <DatePicker SelectedDate="{Binding SelectedEndDate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="10,0,0,0" SelectedDateFormat="Long"/>
            <TextBlock Text="业务员：" Margin="10,0,0,0" Visibility="{Binding IsAdmin,Converter={StaticResource BooleanToVisibilityConverter}}"/>
            <ComboBox x:Name="SaleMan" ItemsSource="{Binding RoleSource}" Width="120" SelectedItem="{Binding SelectRole}"
                      Visibility="{Binding IsAdmin,Converter={StaticResource BooleanToVisibilityConverter}}"
                      Margin="10,0,0,0" DisplayMemberPath="Name" SelectedValuePath="Name"/>

            <TextBox x:Name="SKU" wpf:HintAssist.Hint="SKU"  Margin="10,0,0,0" MinWidth="120" />
            
            <Button x:Name="Query" Width="80" Height="35" Content="查询" Margin="10,0,0,0" />
            <Button x:Name="AdddWare" Width="80" Height="35" Content="新增" Margin="10,0,0,0" />
            <Button x:Name="Export" HorizontalAlignment="Right"  Width="80" Grid.Column="0" Height="35" Content="导出" Margin="10,0,0,0"></Button>
        </StackPanel>


        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="85"/>
                <ColumnDefinition Width="85"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
      
            <!--<Button x:Name="Export" Width="80" Grid.Column="0" Height="35" Content="导出"  />-->

            <!--<TextBox Grid.Column="1" Text="{Binding UPCPar}" Margin=" 0,2,0,2"></TextBox>

            <RadioButton x:Name="Rb" Grid.Column="2" Content="Update" IsChecked="{Binding IsUpdate}"></RadioButton>
            <RadioButton x:Name="Rb2" Grid.Column="3" Content="Delete" IsChecked="{Binding IsUpdate,Converter={StaticResource InvertBooleanConverter}}" Margin="5,0,5,0"></RadioButton>-->
            
            <!--<ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Auto">
                <ListBox x:Name="CountriesListBox" ItemsSource="{Binding Countries}" Style="{StaticResource MaterialDesignFilterChipPrimaryOutlineListBox}">
                </ListBox>
            </ScrollViewer>-->
        </Grid>
       


        <DataGrid x:Name="WareLst" Grid.Row="2" AutoGenerateColumns="False"
                  LoadingRow="Lst_LoadingRow" CanUserAddRows="False" VerticalAlignment="Top"
                  SelectedItem="{Binding SelectWare}" SelectionMode="Single" IsReadOnly="True"
                  cm:Message.Attach="
                  [Event MouseDoubleClick] = [Action Ware_MouseDoubleClick($source,$eventArgs)]"
                  >
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="选中" IsReadOnly="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox  Style="{StaticResource MaterialDesignAccentCheckBox}" 
                                       IsThreeState="False" 
                                       cm:Message.Attach="[Event Click] = [Action Item_CheckedClick($source,$eventArgs)]"
                                       IsChecked="{Binding IsCheck,UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="序号" Width="60" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}"  HorizontalAlignment="Stretch" VerticalAlignment="Center" ></TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="SKU"  Binding="{Binding Sku}"  EditingElementStyle="{StaticResource EditingStyle}"  ElementStyle="{x:Null}"></DataGridTextColumn>
                <DataGridTemplateColumn Header="主图" >
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding MainImageUrl}" Width="40" Height="40">
                                <Image.ToolTip>
                                    <Image Width="120" Source="{Binding MainImageUrl}"/>
                                </Image.ToolTip>
                            </Image>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="产品信息"  >
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button  cm:Message.Attach="[Event Click]= [Action Ware_MouseDoubleClick($source,$eventArgs)]" Style="{StaticResource MaterialDesignOutlinedButton}" Content="编辑"></Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="业务员" Width="auto" Binding="{Binding Operator,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="日期" Width="150"  Binding="{Binding Date,StringFormat='{}{0:yyyy-MM-dd}',UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Grid.Row="3">
            <t:Pagination 
                x:Name="Pagination" Height="40" 
                PageNumber="{Binding PageInfo.PageNum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                ItemsCount="{Binding PageInfo.Total}" 
                PageSize="{Binding PageInfo.PageSize}" 
                PagesCount ="{Binding PageInfo.PagesCount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                PageSizeOptionsEnable="False"
                cm:Message.Attach="[Event PageNumberChanged]= [Action Pagination_OnPageNumberChanged($source,$eventArgs)]"
                ></t:Pagination>
        </Grid>
    </Grid>
</UserControl>
