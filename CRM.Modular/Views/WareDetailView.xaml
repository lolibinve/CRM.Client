<UserControl x:Class="CRM.Modular.Views.WareDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CRM.Modular.Views"
             xmlns:wpf="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cm="http://caliburnmicro.com"
             Language="zh-CN"
             Background="White"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="1300">
    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox">
                <Setter Property="Height" Value="0"></Setter>
                <Setter Property="Margin" Value="10,0,0,0"></Setter>
                <Setter Property="Foreground" Value="#828282"></Setter>
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
                <Setter Property="VerticalContentAlignment" Value="Center"></Setter>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
                <Setter Property="HorizontalAlignment" Value="Left"></Setter>
                <Setter Property="Foreground" Value="Black"></Setter>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <ScrollViewer Margin="10" VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Disabled">
        <Grid >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" x:Name="Grid0" Margin="0,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="产品名称:" Grid.Column="0" FontWeight="Bold"  HorizontalAlignment="Right" VerticalAlignment="Top" />
                <ItemsControl Grid.Column="1" ItemsSource="{Binding LanModel.ItemNames}" Margin="10,0,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical">
                            </StackPanel>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <HierarchicalDataTemplate>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="Iname" Text="{Binding Path=ItemDetailName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Grid.Column="0" Margin="0,0,10,0" Height="auto" MinHeight="30" TextWrapping="Wrap" ></TextBox>
                                <Button Content="-" Grid.Column="1" Tag="{Binding Path=ItemDetailName}" cm:Message.Attach="[Event Click] = [Action SubBtn($source,$eventArgs)]" />
                            </Grid>
                        </HierarchicalDataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button x:Name="AddTb" Content="+" Grid.Column="2" Height="32" VerticalAlignment="Top" Margin="10,0,0,0"/>
            </Grid>

         

            <Grid Grid.Column="1" Margin="0,0,0,0" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.Column="1" x:Name="Grid1"></Grid>

                <TextBlock Text="关键字:" Width="80" Grid.Column="0" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top" />
                <TextBox Text="{Binding LanModel.GenericKeywords}" Grid.Column="1"  Padding="0,0,0,3" Style="{StaticResource MaterialDesignTextBox}" TextWrapping="Wrap"  VerticalAlignment="Top"  />

                <TextBlock Text="短描述:" Width="80" Grid.Row="1" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                <TextBlock VerticalAlignment="Top" HorizontalAlignment="Right" Text="1、" Grid.Row="2"  FontWeight="Bold" />
                <TextBox  VerticalAlignment="Top" Grid.Row="2" Grid.Column="1" Text="{Binding LanModel.BulletPoint1}" Style="{StaticResource MaterialDesignTextBox}" Padding="0,0,0,3" TextWrapping="Wrap"  Width="{Binding ElementName=Grid1, Path=ActualWidth}"/>

                <TextBlock VerticalAlignment="Top" HorizontalAlignment="Right"  Text="2、" Grid.Row="3" FontWeight="Bold"/>
                <TextBox VerticalAlignment="Top"  Grid.Row="3" Grid.Column="1" Text="{Binding LanModel.BulletPoint2}" Style="{StaticResource MaterialDesignTextBox}"  Padding="0,0,0,3" TextWrapping="Wrap"  Width="{Binding ElementName=Grid1, Path=ActualWidth}"/>

                <TextBlock VerticalAlignment="Top" HorizontalAlignment="Right"  Text="3、" Grid.Row="4" FontWeight="Bold"/>
                <TextBox VerticalAlignment="Top"  Grid.Row="4" Grid.Column="1" Text="{Binding LanModel.BulletPoint3}" Style="{StaticResource MaterialDesignTextBox}"  Padding="0,0,0,3" TextWrapping="Wrap"  Width="{Binding ElementName=Grid1, Path=ActualWidth}"/>

                <TextBlock VerticalAlignment="Top" HorizontalAlignment="Right"  Text="4、" Grid.Row="5" FontWeight="Bold"/>
                <TextBox VerticalAlignment="Top" Grid.Row="5" Grid.Column="1" Text="{Binding LanModel.BulletPoint4}" Style="{StaticResource MaterialDesignTextBox}"  Padding="0,0,0,3" TextWrapping="Wrap"  Width="{Binding ElementName=Grid1, Path=ActualWidth}"/>

                <TextBlock VerticalAlignment="Top" HorizontalAlignment="Right"  Text="5、" Grid.Row="6" FontWeight="Bold"/>
                <TextBox VerticalAlignment="Top" Grid.Row="6" Grid.Column="1" Text="{Binding LanModel.BulletPoint5}" Style="{StaticResource MaterialDesignTextBox}"  Padding="0,0,0,3"  TextWrapping="Wrap"  Width="{Binding ElementName=Grid1, Path=ActualWidth}" />

            </Grid>


            <Grid Grid.Column="2" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="产品描述:" Grid.Row="0" FontWeight="Bold" VerticalAlignment="Top" HorizontalAlignment="Left" />

                <Border  Grid.Row="1" x:Name="Grid2" VerticalAlignment="Top" Margin="0,10,0,0">
                    <TextBox  Text="{Binding LanModel.ProductDescription}" Margin="0" AcceptsReturn="True" Height="230"
                        TextWrapping="Wrap" VerticalContentAlignment="Top"  Width="{Binding ElementName=Grid2, Path=ActualWidth}"/>
                </Border>
            </Grid>
            
            
        </Grid>
    </ScrollViewer>
</UserControl>
