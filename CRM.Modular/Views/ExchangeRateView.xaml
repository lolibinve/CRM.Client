<UserControl x:Class="CRM.Modular.Views.ExchangeRateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CRM.Modular.Views"
             xmlns:cm="http://caliburnmicro.com"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" >
                <Setter Property="VerticalContentAlignment" Value="Center"></Setter>
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
                <Setter Property="Width" Value="100"></Setter>
                <Setter Property="Height" Value="30"></Setter>
            </Style>
            <Style TargetType="TextBlock" >
                <Setter Property="VerticalAlignment" Value="Center"></Setter>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button x:Name="Add" Margin="0,0,0,0" Width="80" Content="新 增"/>
            <Button x:Name="Delete" Margin="10,0,0,0" Width="80" Content="删 除"/>
            <Button x:Name="Query" Margin="10,0,0,0" Width="100" Content="查 询"/>
        </StackPanel>

        <DataGrid x:Name="ExchangeLst" Grid.Row="1" AutoGenerateColumns="False" RowHeight="60"
                  CanUserAddRows="False" VerticalAlignment="Top"
                  LoadingRow="Lst_LoadingRow"
                  SelectedItem="{Binding SelectData}" IsReadOnly="True"
                  MouseLeftButtonDown="Lst_MouseLeftButtonDown"
                  cm:Message.Attach="[Event BeginningEdit] = [Action BeginningEdit($eventArgs)];
                  [Event CellEditEnding] = [Action CellEditEnding($eventArgs)];
                  [Event MouseDoubleClick] = [Action ExchangeLst_MouseDoubleClick($source,$eventArgs)]" >
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="选中" IsReadOnly="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox  Style="{StaticResource MaterialDesignAccentCheckBox}" 
                                       IsThreeState="False" 
                                       cm:Message.Attach="[Event Click] = [Action OrderItem_CheckedClick($source,$eventArgs)]"
                                       IsChecked="{Binding IsCheck,UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="序号" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}" HorizontalAlignment="Left" VerticalAlignment="Center" ></TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="货币" Width="100" Binding="{Binding Country,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="中转货币" Width="100" Binding="{Binding MidCurrency,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="原外汇汇率" Width="100" Binding="{Binding InitRatio,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="原回款汇率" Width="100" Binding="{Binding InitBackRatio,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="汇损" Width="100" Binding="{Binding UpdateSourceTrigger=PropertyChanged,Converter={StaticResource DvShowConverter}}"  ElementStyle="{x:Null}"/>
                <DataGridTemplateColumn Header="是否按百分比汇损" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox x:Name="IsDvPercentCheck"  Style="{StaticResource MaterialDesignActionDarkToggleButton}" 
                                    IsThreeState="False"  IsEnabled="False" 
                                    IsChecked="{Binding IsDvPercent,UpdateSourceTrigger=PropertyChanged,Mode=TwoWay}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="外汇汇率" Width="100" Binding="{Binding Ratio,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
                <DataGridTextColumn Header="回款汇率" Width="100" Binding="{Binding BackRatio,UpdateSourceTrigger=PropertyChanged}" ElementStyle="{x:Null}"/>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
