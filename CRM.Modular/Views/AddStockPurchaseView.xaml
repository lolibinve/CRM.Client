<Window x:Class="CRM.Modular.Views.AddStockPurchaseView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CRM.Modular.Views"
        Language="zh-CN"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="688" Width="720"
        WindowStartupLocation="CenterScreen" WindowStyle="ToolWindow">
    <Window.Resources>
        <ResourceDictionary>
            <Style TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
                <Setter Property="Height" Value="40"/>
                <Setter Property="Margin" Value="10,4,0,4"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Foreground" Value="#A7A7A7"/>
            </Style>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CRM.Modular;component/BaseThemes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12,8,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,8,0,8">
            <Grid Margin="8,4,8,4" IsEnabled="{Binding CanEdit}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="108"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="108"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="采购批次:"
                           Visibility="{Binding ShowPurIdRow, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4"
                         Text="{Binding Record.PurId, Mode=TwoWay}"
                         IsReadOnly="True"
                         ToolTip="新增保存后由后端生成；仅展示。"
                         Visibility="{Binding ShowPurIdRow, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="采购时间:"/>
                <DatePicker Grid.Row="1" Grid.Column="1" SelectedDateFormat="Short"
                            SelectedDate="{Binding Record.PurchaseDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding CanEditBaseFields}"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Text="业务员:"/>
                <TextBox Grid.Row="1" Grid.Column="4"
                         Text="{Binding Record.UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsBaseFieldsReadOnly}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="采购账号:"/>
                <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="4" Margin="10,4,0,4"
                          ItemsSource="{Binding AccountOptions}"
                          SelectedItem="{Binding Record.PurchaseAccount, Mode=TwoWay}"
                          IsEditable="False"
                          IsEnabled="{Binding CanEditBaseFields}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="产品编码:"/>
                <ComboBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Margin="10,4,0,4"
                          ItemsSource="{Binding ProductOptions}"
                          DisplayMemberPath="ProductCode"
                          SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                          IsEditable="False"
                          IsEnabled="{Binding CanEditBaseFields}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="产品名称:"/>
                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4"
                         Text="{Binding Record.ProductName, Mode=TwoWay}"
                         IsReadOnly="True"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="采购金额:"/>
                <TextBox Grid.Row="5" Grid.Column="1"
                         Text="{Binding Record.Expense, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanEditBaseFields}"/>

                <TextBlock Grid.Row="5" Grid.Column="3" Text="采购数量:"/>
                <TextBox Grid.Row="5" Grid.Column="4"
                         Text="{Binding Record.Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding CanEditBaseFields}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="头程运费:"/>
                <TextBox Grid.Row="6" Grid.Column="1"
                         Text="{Binding Record.TransFee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="6" Grid.Column="3" VerticalAlignment="Top" Margin="0,10,0,0" Text="说明:"/>
                <TextBlock Grid.Row="6" Grid.Column="4" TextWrapping="Wrap" Foreground="#888" VerticalAlignment="Top" Margin="10,6,0,0"
                           Text="采购金额、头程运费为「元」；单件三项与保存时 unit 字段一致（元，两位小数）。货件到仓时须填写头程运费。"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="单件采购成本:"/>
                <TextBlock Grid.Row="7" Grid.Column="1" Margin="10,4,0,4" Foreground="#333" HorizontalAlignment="Left"
                           Text="{Binding Record.UnitPurchaseCostDisplay}"/>

                <TextBlock Grid.Row="7" Grid.Column="3" Text="单件头程:"/>
                <TextBlock Grid.Row="7" Grid.Column="4" Margin="10,4,0,4" Foreground="#333" HorizontalAlignment="Left"
                           Text="{Binding Record.UnitTransFeeDisplay}"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="合计成本(单件):"/>
                <TextBlock Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="4" Margin="10,4,0,4" Foreground="DarkRed" FontWeight="SemiBold" HorizontalAlignment="Left"
                           Text="{Binding Record.TotalUnitCostDisplay}"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="支付方式:"/>
                <ComboBox Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="4" Margin="10,4,0,4"
                          ItemsSource="{Binding PaymentItems}"
                          DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedPayment, Mode=TwoWay}"
                          IsEnabled="{Binding CanEditBaseFields}"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="货件状态:"/>
                <ComboBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="4" Margin="10,4,0,4"
                          ItemsSource="{Binding ShipmentItems}"
                          DisplayMemberPath="Display"
                          SelectedItem="{Binding SelectedShipment, Mode=TwoWay}"/>

                <TextBlock Grid.Row="11" Grid.Column="0" Text="到仓时间:"/>
                <DatePicker Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="2"
                            SelectedDateFormat="Long"
                            SelectedDate="{Binding Record.InstockDateTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding IsInstockEnabled}"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Text="备注:" VerticalAlignment="Top" Margin="0,10,0,0"/>
                <TextBox Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="4"
                         Text="{Binding Record.Remark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="8"
                         Style="{StaticResource MaterialDesignFilledTextBox}" Margin="10,6,0,0" MinHeight="72"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <Button Name="CloseForm" Content="取消" Height="32" Width="90"/>
            <Button Name="Sure" Content="确认" Height="32" Width="90" Margin="40,0,0,0"
                    Visibility="{Binding CanEdit, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</Window>
