<UserControl x:Class="Aipark.Wpf.Controls.ImageStateControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Aipark.Wpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <Storyboard x:Key="ProgressStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation From="0" To="360" Duration="00:00:03" Storyboard.TargetName="rotateTransform" Storyboard.TargetProperty="Angle" />
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Image x:Name="progressImage" Grid.Row="0" Source="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/loading2.png" Stretch="Uniform"
               Width="40" Height="40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <RotateTransform x:Name="rotateTransform" Angle="0"/>
            </Image.RenderTransform>
        </Image>
        <TextBlock x:Name="progressTitle" Grid.Row="1" Text="图像地址为空" FontSize="28" FontWeight="Black" FontFamily="Black" Foreground="Gray" HorizontalAlignment="Center" />
        <TextBox x:Name="progressContent" Grid.Row="2" Text="图像地址" FontSize="12" FontFamily="Black" Foreground="Gray" 
                 Background="Transparent" BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,6,0,0"/>
        <local:ButtonEx x:Name="progressButton" Grid.Row="3" ButtonStyle="Text" Padding="18,4" CornerRadius="3" Content="刷新" Margin="0,6,0,0"
                        BorderBrush="Silver" MouseOverBorderBrush="Gainsboro" MousePressedBorderBrush="Silver"
                        Background="Transparent" MouseOverBackground="Transparent" MousePressedBackground="Transparent"
                        Foreground="Gray" MouseOverForeground="Gray" MousePressedForeground="Gray" HorizontalAlignment="Center" Click="RefreshButton_Click"/>
    </Grid>
</UserControl>
