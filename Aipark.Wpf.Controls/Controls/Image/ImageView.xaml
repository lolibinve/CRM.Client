<UserControl x:Class="Aipark.Wpf.Controls.ImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Aipark.Wpf.Controls"
             mc:Ignorable="d" 
             Focusable="True"
             Cursor="Hand"  
             ClipToBounds="True"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid x:Name="RootGrid" Background="#0FEFEFEF" ClipToBounds="True" SnapsToDevicePixels="True" MouseWheel="RootGrid_MouseWheel" SizeChanged="RootGrid_SizeChanged">
        <Grid x:Name="LayerGrid" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Image x:Name="Image" Stretch="Fill"
                   Width="{Binding ElementName=LayerGrid,Path=ActualWidth}"
                   Height="{Binding ElementName=LayerGrid,Path=ActualHeight}"/>
            <Thumb x:Name="Thumb" MouseMove="DragThumb_MouseMove"
                   DragStarted="DragThumb_DragStarted" 
                   DragDelta="DragThumb_DragDelta" 
                   DragCompleted="DragThumb_DragCompleted"
                   Width="{Binding ElementName=LayerGrid,Path=ActualWidth}"
                   Height="{Binding ElementName=LayerGrid,Path=ActualHeight}">
                <Thumb.Template>
                    <ControlTemplate>
                        <Rectangle Fill="Transparent"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Canvas x:Name="Canvas" Width="{Binding ElementName=LayerGrid,Path=ActualWidth}" Height="{Binding ElementName=LayerGrid,Path=ActualHeight}" SizeChanged="Canvas_SizeChanged"/>
        </Grid>

        <local:ImageStateControl x:Name="progressControl" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12" Visibility="Collapsed" RefreshButtonClick="ProgressControl_RefreshButtonClick"/>
    </Grid>
</UserControl>
