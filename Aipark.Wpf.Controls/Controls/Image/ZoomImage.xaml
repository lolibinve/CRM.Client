<UserControl x:Class="Aipark.Wpf.Controls.ZoomImage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Aipark.Wpf.Controls"
             mc:Ignorable="d"
             Background="#0FEFEFEF"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Image x:Name="layerImage" Stretch="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=Stretch}"
               HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
        <Thumb x:Name="thumb" Width="{Binding ElementName=layerImage,Path=ActualWidth}" Height="{Binding ElementName=layerImage,Path=ActualHeight}"
               MouseEnter="Thumb_MouseEnter" MouseMove="Thumb_MouseMove" MouseLeave="Thumb_MouseLeave"
               DragStarted="Thumb_DragStarted" DragDelta="Thumb_DragDelta" DragCompleted="Thumb_DragCompleted">
            <Thumb.Template>
                <ControlTemplate>
                    <Rectangle Fill="Transparent"/>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
        <Canvas x:Name="canvas" Width="{Binding ElementName=layerImage,Path=ActualWidth}" Height="{Binding ElementName=layerImage,Path=ActualHeight}" IsHitTestVisible="False"/>
        <Grid x:Name="magnifyingCanvas" Width="{Binding ElementName=layerImage,Path=ActualWidth}" Height="{Binding ElementName=layerImage,Path=ActualHeight}" Visibility="Collapsed" IsHitTestVisible="False">
            <Grid x:Name="magnifyingContent" Width="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=MagnifyingWidth}" 
                  Height="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=MagnifyingHeight}" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Image x:Name="magnifyingImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top" IsHitTestVisible="False"/>
                <Ellipse x:Name="magnifyingBorderEllipse" Width="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=MagnifyingWidth}" 
                         Height="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=MagnifyingHeight}"
                         StrokeThickness="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=MagnifyingBorderThickness}" 
                         Stroke="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=MagnifyingBorderBrush}" />
                <Grid.Clip>
                    <EllipseGeometry x:Name="magnifyingEllipse" Center="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=MagnifyingCenterPoint}"
                                     RadiusX="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=MagnifyingRadiusX}" 
                                     RadiusY="{Binding RelativeSource={RelativeSource Mode= FindAncestor,AncestorType={x:Type local:ZoomImage}},Path=MagnifyingRadiusY}" />
                </Grid.Clip>
            </Grid>
        </Grid>

        <local:ImageStateControl x:Name="progressControl" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12" Visibility="Collapsed" RefreshButtonClick="ProgressControl_RefreshButtonClick"/>
    </Grid>
</UserControl>
