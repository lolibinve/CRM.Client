<local:BaseShape x:Class="Aipark.Wpf.Controls.RectangleShape"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                 xmlns:local="clr-namespace:Aipark.Wpf.Controls"
                 mc:Ignorable="d" 
                 MinWidth="10" MinHeight="10"
                 d:DesignHeight="100" d:DesignWidth="100"
                 Visibility="{Binding Visibility}"
                 IsHitTestVisible="{Binding IsHitTestVisible}"
                 Loaded="BaseShape_Loaded"
                 SizeChanged="BaseShape_SizeChanged">

    <UserControl.Resources>
        <Style x:Key="CornerThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Width="10" Height="10" Fill="{Binding ThumbBrush}" Opacity="0.75"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HorizontalThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Grid Height="6" Background="Transparent">
                            <Rectangle Height="2" HorizontalAlignment="Stretch" VerticalAlignment="Center" Fill="{Binding LineBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VerticalThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Grid Width="6" Background="Transparent">
                            <Rectangle Width="2" HorizontalAlignment="Center" VerticalAlignment="Stretch" Fill="{Binding LineBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid ToolTip="{Binding Tag}"
          Background="Transparent"
          MouseEnter="RootGrid_MouseEnter"
          MouseLeave="RootGrid_MouseLeave"
          PreviewMouseRightButtonUp="RootGrid_PreviewMouseRightButtonUp">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Rectangle x:Name="backgroundRectangle" Fill="Blue" Opacity="0.25" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="Collapsed" Grid.ColumnSpan="2"/>

        <!--左-->
        <Thumb Style="{StaticResource VerticalThumbStyle}" HorizontalAlignment="Left" Cursor="SizeWE" Margin="-3,0,0,0" DragDelta="ResizeThumb_DragDelta"/>
        <!--上-->
        <Thumb Style="{StaticResource HorizontalThumbStyle}" VerticalAlignment="Top" Cursor="SizeNS" Margin="-1,-3,-1,0" DragDelta="ResizeThumb_DragDelta" Grid.ColumnSpan="2"/>
        <!--右-->
        <Thumb Style="{StaticResource VerticalThumbStyle}" HorizontalAlignment="Right" Cursor="SizeWE" Margin="0,0,-3,0" DragDelta="ResizeThumb_DragDelta" Grid.Column="1"/>
        <!--下-->
        <Thumb Style="{StaticResource HorizontalThumbStyle}" VerticalAlignment="Bottom" Cursor="SizeNS" Margin="-1,0,-1,-3" DragDelta="ResizeThumb_DragDelta" Grid.ColumnSpan="2"/>

        <Grid x:Name="tooltipGrid" IsHitTestVisible="False" Margin="48,-10,48,0" HorizontalAlignment="Center" VerticalAlignment="Top" Visibility="Collapsed" Grid.ColumnSpan="2">
            <Rectangle Fill="Black" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Opacity="0.5" RadiusX="2" RadiusY="2" IsHitTestVisible="False"/>
            <TextBlock x:Name="tooltipTextBlock" Text="{Binding Tooltip}" Foreground="{Binding LineBrush}" FontFamily="SimHei" FontSize="8" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,0"/>
        </Grid>

        <Thumb x:Name="ltThumb" Style="{StaticResource CornerThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-5,-5,0,0" Cursor="SizeNWSE" Visibility="Collapsed" DragDelta="ResizeThumb_DragDelta"/>
        <Thumb x:Name="rtThumb" Style="{StaticResource CornerThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0" Cursor="SizeNESW" Visibility="Collapsed" DragDelta="ResizeThumb_DragDelta" Grid.Column="1"/>
        <Thumb x:Name="rbThumb" Style="{StaticResource CornerThumbStyle}" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-5,-5" Cursor="SizeNWSE" Visibility="Collapsed" DragDelta="ResizeThumb_DragDelta" Grid.Column="1"/>
        <Thumb x:Name="lbThumb" Style="{StaticResource CornerThumbStyle}" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-5,0,0,-5" Cursor="SizeNESW" Visibility="Collapsed" DragDelta="ResizeThumb_DragDelta"/>
    </Grid>
</local:BaseShape>
