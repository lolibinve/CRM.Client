<t:TWindow x:Class="Aipark.Wpf.Controls.VertexPropertyEditor"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:t="clr-namespace:Aipark.Wpf.Controls"
           mc:Ignorable="d"
           ResizeMode="NoResize" Topmost="True"
           Title="顶点属性编辑" Height="200" Width="400"
           WindowStartupLocation="CenterScreen"
           Loaded="TWindow_Loaded">

    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="AddButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid x:Name="btnGrid" Background="Transparent" Width="20" Height="10">
                            <Grid Width="12" Height="5" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Line x:Name="line1" Grid.Column="0" X1="0" Y1="5" X2="6" Y2="0" Stroke="Gray" StrokeThickness="1" Margin="0,0,0,0"/>
                                <Line x:Name="line2" Grid.Column="1" X1="0" Y1="0" X2="6" Y2="5" Stroke="Gray" StrokeThickness="1" Margin="0,0,0,0"/>
                            </Grid>
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" RecognizesAccessKey="True" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True"/>
                            <Trigger Property="IsDefaulted" Value="True"/>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Stroke" Value="DeepSkyBlue" TargetName="line1"/>
                                <Setter Property="Stroke" Value="DeepSkyBlue" TargetName="line2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Stroke" Value="#0963B0" TargetName="line1"/>
                                <Setter Property="Stroke" Value="#0963B0" TargetName="line2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"/>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SubButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid x:Name="btnGrid" Background="Transparent" Width="26" Height="10">
                            <Grid Width="12" Height="5" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <Line x:Name="line1" Grid.Column="0" X1="0" Y1="0" X2="6" Y2="5" Stroke="Gray" StrokeThickness="1" Margin="0,0,0,0"/>
                                <Line x:Name="line2" Grid.Column="1" X1="0" Y1="5" X2="6" Y2="0" Stroke="Gray" StrokeThickness="1" Margin="0,0,0,0"/>
                            </Grid>
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" RecognizesAccessKey="True" Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True"/>
                            <Trigger Property="IsDefaulted" Value="True"/>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Stroke" Value="DeepSkyBlue" TargetName="line1"/>
                                <Setter Property="Stroke" Value="DeepSkyBlue" TargetName="line2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Stroke" Value="#0963B0" TargetName="line1"/>
                                <Setter Property="Stroke" Value="#0963B0" TargetName="line2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False"/>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBlock Text="序列号:" Grid.Row="0" Grid.Column="0"/>
        <TextBox  x:Name="serialNumberTbx" Grid.Row="0" Grid.Column="1" IsReadOnly="False" Padding="2,2,20,2" />
        <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" >
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Button Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Style="{StaticResource AddButtonStyle}" Click="AddButton_Click"/>
            <Button Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" Style="{StaticResource SubButtonStyle}" Click="SubButton_Click"/>
        </Grid>

        <TextBlock Text="可见性:" Grid.Row="1" Grid.Column="0"/>
        <ComboBox x:Name="visibilityCmb" Grid.Row="1" Grid.Column="1" VerticalContentAlignment="Center" Margin="0,3" />

        <TextBlock Text="虚实性:" Grid.Row="2" Grid.Column="0"/>
        <ComboBox x:Name="realityCmb" Grid.Row="2" Grid.Column="1" VerticalContentAlignment="Center" Margin="0,3" />

        <TextBlock x:Name="errorTbx" Grid.Row="3" Grid.Column="1" Text="" Foreground="Red" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,12,0,0"/>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12">
            <Button Content="确定" Width="60" Click="ButtonOK_Click" />
            <Button Content="取消" Width="60"  Margin="12,0,0,0" Click="ButtonCancel_Click" />
        </StackPanel>
    </Grid>
</t:TWindow>
