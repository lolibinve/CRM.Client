<UserControl x:Class="Aipark.Wpf.Controls.ImageLayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             Focusable="True"
             Background="Transparent"
             d:DesignWidth="480" d:DesignHeight="270">

    <UserControl.Resources>
        <Storyboard x:Key="MsgShowStory" Storyboard.TargetName="msgBorder">
            <DoubleAnimation From="1" To="0" Duration="0:0:1.5" Storyboard.TargetProperty="Opacity"/>
            <ObjectAnimationUsingKeyFrames  Storyboard.TargetProperty="Visibility" Duration="0:0:4">
                <ObjectAnimationUsingKeyFrames.KeyFrames>
                    <DiscreteObjectKeyFrame KeyTime="0:0:0" >
                        <DiscreteObjectKeyFrame.Value>
                            <Visibility>Visible</Visibility>
                        </DiscreteObjectKeyFrame.Value>
                    </DiscreteObjectKeyFrame>
                    <DiscreteObjectKeyFrame KeyTime="0:0:1.5" >
                        <DiscreteObjectKeyFrame.Value>
                            <Visibility>Collapsed</Visibility>
                        </DiscreteObjectKeyFrame.Value>
                    </DiscreteObjectKeyFrame>
                </ObjectAnimationUsingKeyFrames.KeyFrames>
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>


    <Grid x:Name="RootGrid" Background="Transparent" ClipToBounds="True"
          MouseWheel="ContentGrid_MouseWheel"
          SizeChanged="RootGrid_SizeChanged">
        <Grid x:Name="ContentGrid"
              Width="{Binding ElementName=LayerImage,Path=ActualWidth}"
              Height="{Binding ElementName=LayerImage,Path=ActualHeight}"
              HorizontalAlignment="Left" VerticalAlignment="Top">
            <Image x:Name="LayerImage" Stretch="Uniform" Source="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/alice_blue.jpg"/>
            <Thumb x:Name="thumb" 
                   MouseMove="DragThumb_MouseMove"
                   DragStarted="DragThumb_DragStarted" 
                   DragDelta="DragThumb_DragDelta" 
                   DragCompleted="DragThumb_DragCompleted"
                   Width="{Binding ElementName=LayerImage,Path=ActualWidth}"
                   Height="{Binding ElementName=LayerImage,Path=ActualHeight}">
                <Thumb.Template>
                    <ControlTemplate>
                        <Rectangle Fill="Transparent" />
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
            <Canvas x:Name="PaintCanvas"
                    Width="{Binding ElementName=LayerImage,Path=ActualWidth}" 
                    Height="{Binding ElementName=LayerImage,Path=ActualHeight}"
                    SizeChanged="PaintCanvas_SizeChanged"/>
            <!--水平和竖直线-->
            <Grid x:Name="alignmentGrid" Visibility="Collapsed">
                <Rectangle x:Name="horizonLine" Height="1" Stroke="Gold" StrokeDashArray="5,10" HorizontalAlignment="Stretch" VerticalAlignment="Top" IsHitTestVisible="False"/>
                <Rectangle x:Name="verticalLine" Width="1" Stroke="Gold" StrokeDashArray="5,10" HorizontalAlignment="Left" VerticalAlignment="Stretch" IsHitTestVisible="False"/>
            </Grid>
        </Grid>

        <Border x:Name="msgBorder" Width="100" Height="62" Background="WhiteSmoke" CornerRadius="5" Opacity="1" IsHitTestVisible="False" Visibility="Collapsed">
            <TextBlock x:Name="msgTextBlock" Text="100%" Foreground="Gray" FontWeight="Bold" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
