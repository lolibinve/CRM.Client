<UserControl x:Class="Aipark.Wpf.Controls.SuperTimePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Aipark.Wpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="200"
             FontFamily="Segoe UI" FontSize="13"
             BorderBrush="Silver" BorderThickness="1"
             Background="White" Foreground="Black"
             Loaded="UserControl_Loaded"
             KeyDown="UserControl_KeyDown"
             MouseWheel="UserControl_MouseWheel"
             LostFocus="UserControl_LostFocus">

    <UserControl.Resources>
        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="2" SnapsToDevicePixels="true" Stroke="Transparent" StrokeThickness="0" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type RadioButton}">
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Padding" Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Grid x:Name="templateRoot" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="contentPresenter" Grid.Column="1" Focusable="False" HorizontalAlignment="Right" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasContent" Value="true">
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="true">
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                            </Trigger>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter Property="Background" TargetName="templateRoot" Value="#FF5593FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="{x:Null}">
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="1">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" TextBlock.FontSize="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperTimePicker}},Path=TimeFontSize}">
            <RadioButton x:Name="hourRadionButton" Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperTimePicker}},Path=Hour}"
                         Tag="Hour" Checked="DateTimeFieldRadioButton_Checked" Unchecked="DateTimeFieldRadioButton_Unchecked"/>
            <TextBlock Grid.Column="7" Text=":" IsHitTestVisible="False" VerticalAlignment="Center" Margin="0.5,0"/>
            <RadioButton x:Name="minuteRadionButton" Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperTimePicker}},Path=Minute}"
                         Tag="Minute" Checked="DateTimeFieldRadioButton_Checked" Unchecked="DateTimeFieldRadioButton_Unchecked"/>
            <TextBlock Grid.Column="9" Text=":" IsHitTestVisible="False" VerticalAlignment="Center" Margin="0.5,0"/>
            <RadioButton x:Name="secondRadionButton" Content="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperTimePicker}},Path=Second}"
                         Tag="Second" Padding="0,3,3,3" Checked="DateTimeFieldRadioButton_Checked" Unchecked="DateTimeFieldRadioButton_Unchecked"/>
        </StackPanel>
    </Grid>
</UserControl>
