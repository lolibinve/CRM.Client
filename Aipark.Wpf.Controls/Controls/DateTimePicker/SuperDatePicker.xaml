<UserControl x:Class="Aipark.Wpf.Controls.SuperDatePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Aipark.Wpf.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="CalendarItemButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperDatePicker}},Path=ItemFontSize}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Gainsboro"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="1"/>
        </Style>

        <Style x:Key="HeaderButtonStyle" TargetType="{x:Type local:ButtonEx}">
            <Setter Property="FontSize" Value="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperDatePicker}},Path=HeaderFontSize}"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="DimGray"/>
            <Setter Property="MouseOverBackground" Value="Transparent"/>
            <Setter Property="MouseOverForeground" Value="#0963B0"/>
            <Setter Property="MousePressedBackground" Value="Transparent"/>
            <Setter Property="MousePressedForeground" Value="#3A8EE6"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <local:ButtonEx x:Name="PreviousButton" Grid.Column="0" Content="&lt;" Style="{StaticResource HeaderButtonStyle}" FontWeight="Black" 
                        HorizontalAlignment="Left" VerticalAlignment="Center" Margin="18,0,0,0" Click="PreviousButton_Click"/>
        <local:ButtonEx x:Name="HeaderButton" Grid.Column="1" Content="2021年09月" Style="{StaticResource HeaderButtonStyle}" Foreground="Black" 
                        HorizontalAlignment="Center" VerticalAlignment="Center" Click="HeaderButton_Click"/>
        <local:ButtonEx x:Name="NextButton" Grid.Column="2" Content="&gt;" Style="{StaticResource HeaderButtonStyle}" FontWeight="Black" 
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0" Click="NextButton_Click"/>

        <Grid x:Name="MonthDaysView" Grid.Row="1" Grid.ColumnSpan="3" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="7*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="一" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperDatePicker}},Path=ItemFontSize}"/>
                <TextBlock Grid.Column="1" Text="二" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperDatePicker}},Path=ItemFontSize}"/>
                <TextBlock Grid.Column="2" Text="三" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperDatePicker}},Path=ItemFontSize}"/>
                <TextBlock Grid.Column="3" Text="四" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperDatePicker}},Path=ItemFontSize}"/>
                <TextBlock Grid.Column="4" Text="五" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperDatePicker}},Path=ItemFontSize}"/>
                <TextBlock Grid.Column="5" Text="六" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperDatePicker}},Path=ItemFontSize}"/>
                <TextBlock Grid.Column="6" Text="日" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:SuperDatePicker}},Path=ItemFontSize}"/>
            </Grid>
            <Grid Grid.Row="1" x:Name="MonthDaysGrid" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Grid.Column="0" Content="30" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="0" Grid.Column="1" Content="31" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="0" Grid.Column="2" Content="1" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="0" Grid.Column="3" Content="2" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="0" Grid.Column="4" Content="3" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="0" Grid.Column="5" Content="4" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="0" Grid.Column="6" Content="5" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="1" Grid.Column="0" Content="6" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="1" Grid.Column="1" Content="7" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="1" Grid.Column="2" Content="8" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="1" Grid.Column="3" Content="9" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="1" Grid.Column="4" Content="10" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="1" Grid.Column="5" Content="11" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="1" Grid.Column="6" Content="12" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="2" Grid.Column="0" Content="13" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="2" Grid.Column="1" Content="14" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="2" Grid.Column="2" Content="15" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="2" Grid.Column="3" Content="16" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="2" Grid.Column="4" Content="17" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="2" Grid.Column="5" Content="18" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="2" Grid.Column="6" Content="19" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="3" Grid.Column="0" Content="20" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="3" Grid.Column="1" Content="21" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="3" Grid.Column="2" Content="22" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="3" Grid.Column="3" Content="23" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="3" Grid.Column="4" Content="24" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="3" Grid.Column="5" Content="25" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="3" Grid.Column="6" Content="26" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="4" Grid.Column="0" Content="27" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="4" Grid.Column="1" Content="28" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="4" Grid.Column="2" Content="29" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="4" Grid.Column="3" Content="30" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="4" Grid.Column="4" Content="1" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="4" Grid.Column="5" Content="2" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="4" Grid.Column="6" Content="3" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="5" Grid.Column="0" Content="4" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="5" Grid.Column="1" Content="5" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="5" Grid.Column="2" Content="6" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="5" Grid.Column="3" Content="7" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="5" Grid.Column="4" Content="8" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="5" Grid.Column="5" Content="9" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
                <Button Grid.Row="6" Grid.Column="6" Content="10" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="DayButton_Click"/>
            </Grid>
        </Grid>

        <Grid x:Name="YearMonthsView" Grid.Row="1" Grid.ColumnSpan="3" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="1月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content="2月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="3月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="0" Grid.Column="3" Content="4月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="1" Grid.Column="0" Content="5月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="6月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="7月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="8月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="2" Grid.Column="0" Content="9月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="10月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="11月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
            <Button Grid.Row="2" Grid.Column="3" Content="12月" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="MonthButton_Click"/>
        </Grid>

        <Grid x:Name="YearsView" Grid.Row="1" Grid.ColumnSpan="3" Visibility="Hidden">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="2019" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="0" Grid.Column="1" Content="2020" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="0" Grid.Column="2" Content="2021" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="0" Grid.Column="3" Content="2022" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="1" Grid.Column="0" Content="2023" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="1" Grid.Column="1" Content="2024" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="1" Grid.Column="2" Content="2025" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="1" Grid.Column="3" Content="2026" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="2" Grid.Column="0" Content="2027" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="2" Grid.Column="1" Content="2028" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="2" Grid.Column="2" Content="2029" Foreground="Black" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
            <Button Grid.Row="2" Grid.Column="3" Content="2030" Foreground="Silver" Style="{StaticResource CalendarItemButtonStyle}" Click="YearButton_Click"/>
        </Grid>
    </Grid>
</UserControl>
