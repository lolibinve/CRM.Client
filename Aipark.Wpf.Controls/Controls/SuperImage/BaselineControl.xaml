<UserControl x:Class="Aipark.Wpf.Controls.SuperImage.BaselineControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Rectangle x:Name="xRectangle" Width="1" Stroke="Gold" StrokeDashArray="5,10" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
        <Rectangle x:Name="yRectangle" Height="1" Stroke="Gold" StrokeDashArray="5,10" HorizontalAlignment="Stretch" VerticalAlignment="Top"/>
    </Grid>
</UserControl>
