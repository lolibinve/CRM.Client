        <local:NavigationMenuShrinkDataTemplateSelector x:Key="NavigationMenuShrinkDataTemplateSelector"/>
        <DataTemplate x:Key="ShrinkRadioButtonTemplate">
            <RadioButton Style="{StaticResource ShrinkRadioButtonStyle}" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" DataContext="{Binding}"
                         GroupName="ShrinkChildrenGroup" Content="{Binding Name}" FontSize="13" Foreground="Black" IsChecked="{Binding IsChecked}" Click="MenuItemRadioButton_Click">
            </RadioButton>
        </DataTemplate>
        <DataTemplate x:Key="ShrinkExpanderTemplate">
            <Expander Style="{StaticResource ShrinkExpanderStyle}" Header="{Binding Name}" DataContext="{Binding}" FontSize="13" IsExpanded="False">
                <Expander.Content>
                    <ItemsControl ItemsSource="{Binding RelativeSource ={RelativeSource Mode=FindAncestor,AncestorType=Expander}, Path=DataContext.Children}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Style="{StaticResource ShrinkChildRadioButtonStyle}" Background="Transparent" BorderBrush="Transparent" BorderThickness="1"
                                             GroupName="ShrinkChildrenGroup" Content="{Binding Name}" FontSize="13" Foreground="Black" 
                                             IsChecked="{Binding IsChecked}" DataContext="{Binding}" Click="MenuItemRadioButton_Click">
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander.Content>
            </Expander>

        </DataTemplate>


        <local:NavigationMenuInlineDataTemplateSelector x:Key="NavigationMenuInlineDataTemplateSelector"/>
        <DataTemplate x:Key="InlineDataTemplate">
            <Expander Style="{StaticResource InlineHighExpanderStyle}" Header="{Binding Name}" DataContext="{Binding}" IsExpanded="False" 
                      FontSize="13" Foreground="White" Background="Transparent">
                <Expander.Content>
                    <ItemsControl ItemsSource="{Binding RelativeSource ={RelativeSource Mode=FindAncestor,AncestorType=Expander}, Path=DataContext.Children}"
                                  ItemTemplateSelector="{StaticResource NavigationMenuInlineDataTemplateSelector}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                    </ItemsControl>
                </Expander.Content>
            </Expander>
        </DataTemplate>
        <DataTemplate x:Key="InlineRadioButtonTemplate">
            <RadioButton Style="{StaticResource InlineHighRadioButtonStyle}" Background="Transparent" BorderBrush="Transparent" BorderThickness="1"
                         GroupName="InlineChildrenGroup" Content="{Binding Name}" FontSize="13" Foreground="White" 
                         IsChecked="{Binding IsChecked}" DataContext="{Binding}" Click="MenuItemRadioButton_Click">
            </RadioButton>
        </DataTemplate>
        <DataTemplate x:Key="InlineExpanderTemplate">
            <Expander Style="{StaticResource InlineLowExpanderStyle}" Header="{Binding Name}" DataContext="{Binding}" IsExpanded="False" 
                      FontSize="13" Foreground="White" Background="Transparent">
                <Expander.Content>
                    <ItemsControl ItemsSource="{Binding RelativeSource ={RelativeSource Mode=FindAncestor,AncestorType=Expander}, Path=DataContext.Children}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Style="{StaticResource InlineLowRadioButtonStyle}" Background="Transparent" BorderBrush="Transparent" BorderThickness="1"
                                             GroupName="InlineChildrenGroup" Content="{Binding Name}" FontSize="13" Foreground="White" 
                                             IsChecked="{Binding IsChecked}" DataContext="{Binding}" Click="MenuItemRadioButton_Click">
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Expander.Content>
            </Expander>
        </DataTemplate>
    </UserControl.Resources>


    <Grid TextBlock.FontFamily="Simsun">
        <Grid.RowDefinitions>
            <RowDefinition Height="24" />
            <RowDefinition Height="48" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="Column1" Width="48"/>
            <ColumnDefinition x:Name="Column2" Width="0"/>
        </Grid.ColumnDefinitions>

        <Rectangle Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" Fill="#1773BD"/>
        <ToggleButton Grid.Row="1" Grid.Column="0" Style="{StaticResource MenuToggleButtonStyle}" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                      Width="48" Height="48" Background="Transparent" BorderBrush="Transparent" BorderThickness="1" DataContext="{Binding}"
                      IsChecked="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:NavigationMenu}},Path=InlineMode}">
            <ToggleButton.Content>
                <Image Source="pack://application:,,,/Aipark.Wpf.Controls;component/Controls/Expander/Images/menu.png" Width="48" Height="48" Stretch="None"/>
            </ToggleButton.Content>
        </ToggleButton>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden">
            <ItemsControl x:Name="InlineItemsControl" ItemTemplate="{StaticResource InlineDataTemplate}"
                      ItemsSource="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:NavigationMenu}},Path=ItemsSource}"
                      ScrollViewer.VerticalScrollBarVisibility="Visible" Visibility="Collapsed">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <ItemsControl x:Name="ShrinkItemsControl" Grid.Row="2"
                      ItemsSource="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:NavigationMenu}},Path=ItemsSource}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Style="{StaticResource MenuButtonStyle}" Background="Transparent" BorderBrush="Transparent" BorderThickness="1"
                            Foreground="White" ToolTip="{Binding Name}" Click="ShrinkMenuButton_Click">
                        <Button.Content>
                            <Image Source="{Binding Icon}" Width="48" Height="48" Stretch="None"/>
                        </Button.Content>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Border x:Name="ShrinkChildrenPanel" Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                Background="WhiteSmoke" BorderBrush="Gainsboro" BorderThickness="0,0,1,0" 
                DataContext="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type local:NavigationMenu}},Path=ShrinkChildrenPanelDataContext}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="48" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding Name}" Grid.Row="1" FontSize="14" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="18,2,0,0"/>
                <Rectangle Fill="Gainsboro" Grid.Row="1" Height="1" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="3,0,3,3"/>
                <ItemsControl x:Name="ShrinkChildrenItemsControl" Grid.Row="2" ItemsSource="{Binding Children}" 
                          ItemTemplateSelector="{StaticResource NavigationMenuShrinkDataTemplateSelector}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </Border>

    </Grid>
</UserControl>
