<UserControl x:Class="Aipark.Wpf.Controls.DropdownTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Aipark.Wpf.Controls"
             xmlns:cvt="clr-namespace:Aipark.Wpf.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="200">

    <UserControl.Resources>
        <cvt:DisplayMemberConverter x:Key="DisplayMemberConverter"/>

        <Style x:Key="PopupToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border Background="{TemplateBinding Background}" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" CornerRadius="3">
                            <Path x:Name="path" Data="M 0,0 L 6,6 12,0 10,0 6,4 2,0 Z" Fill="{TemplateBinding BorderBrush}"  
                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                  Margin="{TemplateBinding Padding}" RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Path.RenderTransform>
                            </Path>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Button.IsDefaulted" Value="true"/>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Fill" Value="DeepSkyBlue" TargetName="path"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter Property="Fill" Value="#0963B0" TargetName="path"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false"/>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="White" BorderBrush="Silver" BorderThickness="1" CornerRadius="2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <local:TextBoxEx x:Name="selectedTbx" Grid.Column="0" Watermark="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:DropdownTextBox}},Path=Watermark}" 
                 Background="White" Foreground="Black" BorderThickness="0" 
                 VerticalContentAlignment="Center" Padding="1,2,1,2" Margin="1" 
                 TextChanged="SelectedTbx_TextChanged"/>
            <ToggleButton Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Style="{DynamicResource PopupToggleButtonStyle}" 
                          Padding="6,0" IsChecked="{Binding ElementName=itemsPopup,Mode=TwoWay,Path=IsOpen}"/>

            <Popup x:Name="itemsPopup" PopupAnimation="Fade" PlacementTarget="{Binding ElementName=selectedTbx}" 
               Placement="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:DropdownTextBox}},Path=Placement}" 
               AllowsTransparency="True" StaysOpen="False" IsOpen="False" VerticalOffset="1">
                <Border x:Name="itemsBorder" Background="White" BorderBrush="Silver" BorderThickness="1"
                    Width="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:DropdownTextBox}},Path=PopupWidth}" 
                    Height="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:DropdownTextBox}},Path=PopupHeight}" >
                    <ScrollViewer x:Name="scrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="itemsControl" ItemsSource="{Binding ItemsSource}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <RadioButton GroupName="itemRadioButton" DataContext="{Binding}" Click="RadioButton_Click">
                                        <RadioButton.Template>
                                            <ControlTemplate TargetType="{x:Type RadioButton}">
                                                <Border x:Name="templateRoot" Background="Transparent" Height="24" BorderBrush="Transparent" BorderThickness="0" Padding="4,0,0,0">
                                                    <TextBlock x:Name="itemTbx" Foreground="Black" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                                        <TextBlock.Text>
                                                            <MultiBinding Converter="{StaticResource DisplayMemberConverter}">
                                                                <Binding />
                                                                <Binding Path="DisplayMemberPath" RelativeSource="{RelativeSource AncestorType={x:Type local:DropdownTextBox}}"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="HasContent" Value="true">
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter Property="Background" Value="Gainsboro" TargetName="templateRoot"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="false">
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="true">
                                                        <Setter Property="BorderThickness" Value="2,1" TargetName="templateRoot"/>
                                                        <Setter Property="BorderBrush" Value="Transparent" TargetName="templateRoot"/>
                                                        <Setter Property="Background" Value="WhiteSmoke" TargetName="templateRoot"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="true">
                                                        <Setter Property="Background" TargetName="templateRoot" Value="WhiteSmoke"/>
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="{x:Null}">
                                                        <Setter Property="Background" TargetName="templateRoot" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </RadioButton.Template>
                                    </RadioButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
