<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Aipark.Wpf.Controls">

    <Style x:Key="IconButtonBaseStyle" TargetType="{x:Type local:ButtonEx}">
        <Setter Property="ButtonStyle" Value="Icon"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="MouseOverBackground" Value="Transparent"/>
        <Setter Property="MousePressedBackground" Value="Transparent"/>
    </Style>

    <Style x:Key="DeleteImageButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconButtonBaseStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/delete.png" />
    </Style>

</ResourceDictionary>