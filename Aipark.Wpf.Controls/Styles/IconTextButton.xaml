<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Aipark.Wpf.Controls">

    <!--图标文本按钮样式-->
    <Style x:Key="IconTextButtonStyle" TargetType="{x:Type local:ButtonEx}">
        <Setter Property="ButtonStyle" Value="IconText"/>
        <Setter Property="Padding" Value="5,4"/>
        <Setter Property="IconWidth" Value="15"/>
        <Setter Property="IconHeight" Value="15"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="RefreshIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/refresh.png" />
        <Setter Property="Content" Value="刷新"/>
    </Style>
    <Style x:Key="CreateIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/add.png" />
        <Setter Property="Content" Value="新增"/>
    </Style>
    <Style x:Key="EditIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/edit2.png" />
        <Setter Property="Content" Value="编辑"/>
    </Style>
    <Style x:Key="DeleteIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/delete2.png" />
        <Setter Property="Content" Value="删除"/>
    </Style>

    <Style x:Key="PlayIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/play.png" />
        <Setter Property="Content" Value="开始播放"/>
    </Style>
    <Style x:Key="PauseIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/pause.png" />
        <Setter Property="Content" Value="暂停播放"/>
    </Style>
    <Style x:Key="StopIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/stop.png" />
        <Setter Property="Content" Value="停止播放"/>
    </Style>

    <Style x:Key="FolderIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/folder.png" />
        <Setter Property="Content" Value="文件夹"/>
    </Style>
    <Style x:Key="SaveIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/save.png" />
        <Setter Property="Content" Value="保存"/>
    </Style>
    <Style x:Key="FindIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/find.png" />
        <Setter Property="Content" Value="查找"/>
    </Style>
    <Style x:Key="PasswordIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/key.png" />
        <Setter Property="Content" Value="修改密码"/>
    </Style>
    <Style x:Key="GrantAppxIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/package.png" />
        <Setter Property="Content" Value="应用授权"/>
    </Style>
    <Style x:Key="TopicIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/topic.png" />
        <Setter Property="Content" Value="主题"/>
    </Style>
    <Style x:Key="GrantUserIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/user.png" />
        <Setter Property="Content" Value="用户授权"/>
    </Style>
    <Style x:Key="PackageIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/breafcase.png" />
        <Setter Property="Content" Value="版本发布"/>
    </Style>
    <Style x:Key="BulbOnIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/bulb_on.png" />
        <Setter Property="Content" Value="授权"/>
    </Style>
    <Style x:Key="BulbOffIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}" BasedOn="{StaticResource IconTextButtonStyle}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/bulb_off.png" />
        <Setter Property="Content" Value="取消"/>
    </Style>

    <Style x:Key="WindowSettingsIconTextButtonStyle" TargetType="{x:Type local:ButtonEx}">
        <Setter Property="ButtonStyle" Value="IconText"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="IconWidth" Value="15"/>
        <Setter Property="IconHeight" Value="15"/>
        <Setter Property="CornerRadius" Value="2"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ModifyPasswordImageIconButtonStyle" BasedOn="{StaticResource WindowSettingsIconTextButtonStyle}" TargetType="{x:Type local:ButtonEx}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/key.png"/>
        <Setter Property="Content" Value="注销登录"/>
    </Style>

    <Style x:Key="ShutdownImageIconButtonStyle" BasedOn="{StaticResource WindowSettingsIconTextButtonStyle}" TargetType="{x:Type local:ButtonEx}">
        <Setter Property="IconSource" Value="pack://application:,,,/Aipark.Wpf.Controls;component/Resources/Images/shutdown.png"/>
        <Setter Property="Content" Value="修改密码"/>
    </Style>

</ResourceDictionary>