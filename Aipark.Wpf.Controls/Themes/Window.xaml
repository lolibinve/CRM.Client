<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Aipark.Wpf.Controls">

    <Style TargetType="{x:Type local:TWindow}">
        <!--允许窗口透明在承载WinForm控件时可能存在BUG-->
        <Setter Property="AllowsTransparency" Value="False"/>
        <Setter Property="FontFamily" Value="SimSun"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="Silver"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="MinWidth" Value="300"/>
        <Setter Property="MinHeight" Value="150"/>
        <Setter Property="HeaderHeight" Value="32"/>
        <Setter Property="HeaderBackground" Value="#0476BF"/>
        <Setter Property="WindowButtonForeground" Value="White"/>
        <Setter Property="WindowButtonMouseOverBackground" Value="DeepSkyBlue"/>
        <Setter Property="WindowButtonPressedBackground" Value="#0EA8E8"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="TitleMargin" Value="12,0,0,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TWindow}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="border" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition />
                                </Grid.RowDefinitions>

                                <!-- 标题栏 -->
                                <Border x:Name="TemplatePart_HeaderContainer" Grid.Row="0" Background="{TemplateBinding HeaderBackground}" Height="{TemplateBinding HeaderHeight}" Padding="{TemplateBinding HeaderPadding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition />
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ContentPresenter Grid.ColumnSpan="5" ContentSource="HeaderContent"/>

                                        <Image Grid.Column="0" Source="{TemplateBinding Icon}" Width="{TemplateBinding IconWidth}" Height="{TemplateBinding IconHeight}" Stretch="Uniform" 
                                               Visibility="{TemplateBinding IconVisibility}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding IconMargin}"/>

                                        <TextBox Grid.Column="1" Text="{TemplateBinding Title}" Foreground="{TemplateBinding TitleForeground}" FontFamily="{TemplateBinding TitleFontFamily}" 
                                                 FontSize="{TemplateBinding TitleFontSize}" FontWeight="{TemplateBinding TitleFontWeight}" Margin="{TemplateBinding TitleMargin}" 
                                                 HorizontalAlignment="{TemplateBinding TitleHorizontalAlignment}" VerticalAlignment="Center" TextWrapping="NoWrap" BorderThickness="0" Background="Transparent"
                                                 IsReadOnly="True" IsHitTestVisible="{TemplateBinding TitleSelectable}"/>

                                        <Button x:Name="TemplatePart_MinimizeButton" Grid.Column="2" IsTabStop="False" Cursor="Hand"
                                                Width="{TemplateBinding WindowButtonWidth}" Height="{TemplateBinding WindowButtonHeight}" 
                                                Style="{DynamicResource WindowMinimizeButtonStyle}" ToolTip="最小化" VerticalAlignment="Top"/>
                                        <ToggleButton x:Name="TemplatePart_MaximizeButton" Grid.Column="3" IsTabStop="False" Cursor="Hand" 
                                                      Width="{TemplateBinding WindowButtonWidth}" Height="{TemplateBinding WindowButtonHeight}"
                                                      Style="{DynamicResource WindowMaximizeButtonStyle}" ToolTip="最大化" VerticalAlignment="Top"/>
                                        <Button x:Name="TemplatePart_CloseButton" Grid.Column="4" IsTabStop="False" Cursor="Hand" 
                                                Width="{TemplateBinding WindowButtonWidth}" Height="{TemplateBinding WindowButtonHeight}"
                                                Style="{DynamicResource WindowCloseButtonStyle}" ToolTip="关闭" VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>
                                <AdornerDecorator Grid.Row="1" >
                                    <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                </AdornerDecorator>
                                <!-- 附加组件 -->
                                <ContentPresenter Grid.RowSpan="2" ContentSource="AttachedContent"/>
                            </Grid>
                        </Border>
                        <Grid x:Name="thumbsGrid">
                            <Grid.Resources>
                                <Style TargetType="{x:Type Thumb}">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate>
                                                <Rectangle Fill="Transparent"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>
                            <Thumb x:Name="TemplatePart_LeftThumb" Width="8" VerticalAlignment="Stretch" HorizontalAlignment="Left" Cursor="SizeWE"/>
                            <Thumb x:Name="TemplatePart_TopThumb" Height="8" VerticalAlignment="Top" HorizontalAlignment="Stretch" Cursor="SizeNS" />
                            <Thumb x:Name="TemplatePart_RightThumb" Width="8" VerticalAlignment="Stretch" HorizontalAlignment="Right" Cursor="SizeWE" />
                            <Thumb x:Name="TemplatePart_BottomThumb" Height="8" VerticalAlignment="Bottom" HorizontalAlignment="Stretch" Cursor="SizeNS" />

                            <ResizeGrip x:Name="TemplatePart_ResizeGrip" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,1,1"/>

                            <Thumb x:Name="TemplatePart_LeftTopThumb" Width="9" Height="9" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE"/>
                            <Thumb x:Name="TemplatePart_RightTopThumb" Width="9" Height="9" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" />
                            <Thumb x:Name="TemplatePart_RightBottomThumb" Width="9" Height="9" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" />
                            <Thumb x:Name="TemplatePart_LeftBottomThumb" Width="9" Height="9" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" />
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ResizeMode" Value="NoResize">
                            <Setter TargetName="TemplatePart_MinimizeButton" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TemplatePart_MaximizeButton" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="thumbsGrid" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ResizeMode" Value="CanMinimize">
                            <Setter TargetName="TemplatePart_MaximizeButton" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="thumbsGrid" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ResizeMode" Value="CanResize">
                            <Setter TargetName="TemplatePart_ResizeGrip" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ResizeMode" Value="CanResizeWithGrip">
                            <Setter TargetName="TemplatePart_ResizeGrip" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <!--最大化时不显示边框和调整大小-->
                        <Trigger SourceName="TemplatePart_MaximizeButton" Property="IsChecked" Value="True" >
                            <Setter TargetName="border" Property="BorderThickness" Value="0" />
                            <Setter TargetName="thumbsGrid" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>